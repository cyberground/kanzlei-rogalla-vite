---
const year = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-main">
    <div class="container footer-main__grid">

      <div class="footer-col footer-col--brand">
        <a href="/" class="footer-logo" aria-label="Kanzlei Rogalla – Startseite">
          <img src="/images/logo.png" alt="Kanzlei Rogalla" class="footer-logo__img" loading="lazy" />
          <span class="footer-logo__name">Kanzlei Rogalla</span>
          <span class="footer-logo__tagline">Rechtsanwältin · Insolvenz & Erbrecht</span>
        </a>
        <p class="footer-desc">
          Kompetente und persönliche Rechtsberatung in Insolvenzrecht, Erbrecht und
          Forderungsmanagement. Drei Standorte in Mittelhessen.
        </p>
        <address class="footer-contact" style="font-style: normal;">
          <a href="tel:+4966317580179" class="footer-contact__link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.4 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012.31 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            +49 6631 / 758 017 9
          </a>
          <a href="mailto:info@kanzlei-rogalla.de" class="footer-contact__link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            info@kanzlei-rogalla.de
          </a>
        </address>
      </div>

      <div class="footer-col">
        <h3 class="footer-col__title">Leistungen</h3>
        <ul class="footer-links" role="list">
          <li><a href="/services/insolvenz" class="footer-link">Insolvenzrecht</a></li>
          <li><a href="/services/erbrecht" class="footer-link">Erbrecht</a></li>
          <li><a href="/services/forderung" class="footer-link">Forderungsmanagement</a></li>
          <li><a href="/services/vorsorge-nachlass" class="footer-link">Vorsorge & Nachlass</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-col__title">Kanzlei</h3>
        <ul class="footer-links" role="list">
          <li><a href="/team" class="footer-link">Über Christina Rogalla</a></li>
          <li><a href="/blog" class="footer-link">Ratgeber & Rechtsnews</a></li>
          <li><a href="/kontakt" class="footer-link">Kontakt & Erstberatung</a></li>
          <li><a href="/downloads" class="footer-link">Downloads & Formulare</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-col__title">Standorte</h3>
        <div class="footer-locations">
          <div class="footer-location">
            <span class="footer-location__city">Alsfeld (Hauptkanzlei)</span>
            <span class="footer-location__addr">Grünberger Straße 14<br />36304 Alsfeld</span>
          </div>
          <div class="footer-location">
            <span class="footer-location__city">Gießen</span>
            <span class="footer-location__addr">Beratung nach Vereinbarung</span>
          </div>
          <div class="footer-location">
            <span class="footer-location__city">Offenbach</span>
            <span class="footer-location__addr">Beratung nach Vereinbarung</span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom__inner">
      <p class="footer-bottom__copy">
        © {year} Rechtsanwaltskanzlei Christina Rogalla. Alle Rechte vorbehalten.
      </p>
      <nav class="footer-legal" aria-label="Rechtliches">
        <a href="/impressum" class="footer-legal__link">Impressum</a>
        <a href="/datenschutz" class="footer-legal__link">Datenschutz</a>
      </nav>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background-color: var(--navy-dark);
  background-image: url('/images/footer-bg.jpg');
  background-size: cover;
  background-position: center;
  background-blend-mode: multiply;
  color: rgb(255 255 255 / 0.65);
}

.footer-main { padding-block: var(--space-16) var(--space-12); }

.footer-main__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-10);
}

@media (min-width: 640px) {
  .footer-main__grid { grid-template-columns: repeat(2, 1fr); }
}

@media (min-width: 1024px) {
  .footer-main__grid { grid-template-columns: 2fr 1fr 1fr 1.5fr; }
}

.footer-logo {
  display: flex;
  flex-direction: column;
  gap: 4px;
  text-decoration: none;
  margin-bottom: var(--space-5);
}

.footer-logo__img {
  height: 55px;
  width: auto;
  filter: brightness(0) invert(1);
  margin-bottom: var(--space-2);
}

.footer-logo__name {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: var(--white);
  letter-spacing: var(--letter-spacing-tight);
  line-height: 1;
}

.footer-logo__tagline {
  font-size: 0.65rem;
  font-weight: var(--font-weight-medium);
  letter-spacing: var(--letter-spacing-wide);
  text-transform: uppercase;
  color: var(--gold-light);
}

.footer-desc {
  font-size: var(--font-size-sm);
  line-height: var(--line-height-relaxed);
  color: rgb(255 255 255 / 0.55);
  margin-bottom: var(--space-6);
  max-width: 30ch;
}

.footer-contact { display: flex; flex-direction: column; gap: var(--space-2); }

.footer-contact__link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--font-size-sm);
  color: rgb(255 255 255 / 0.65);
  text-decoration: none;
  transition: color var(--transition-fast);
}
.footer-contact__link:hover { color: var(--gold-light); }

.footer-col__title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--white);
  letter-spacing: var(--letter-spacing-wide);
  text-transform: uppercase;
  margin-bottom: var(--space-5);
}

.footer-links { display: flex; flex-direction: column; gap: var(--space-3); }

.footer-link {
  font-size: var(--font-size-sm);
  color: rgb(255 255 255 / 0.6);
  text-decoration: none;
  transition: color var(--transition-fast);
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
}
.footer-link:hover { color: var(--gold-light); }

.footer-locations { display: flex; flex-direction: column; gap: var(--space-5); }

.footer-location { display: flex; flex-direction: column; gap: var(--space-1); }

.footer-location__city {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--gold-light);
}

.footer-location__addr {
  font-size: var(--font-size-xs);
  color: rgb(255 255 255 / 0.45);
  line-height: var(--line-height-relaxed);
}

.footer-bottom {
  border-top: 1px solid rgb(255 255 255 / 0.1);
  padding-block: var(--space-6);
}

.footer-bottom__inner {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  align-items: center;
  text-align: center;
}

@media (min-width: 640px) {
  .footer-bottom__inner {
    flex-direction: row;
    justify-content: space-between;
    text-align: left;
  }
}

.footer-bottom__copy {
  font-size: var(--font-size-xs);
  color: rgb(255 255 255 / 0.35);
  max-width: none;
}

.footer-legal { display: flex; align-items: center; gap: var(--space-6); }

.footer-legal__link {
  font-size: var(--font-size-xs);
  color: rgb(255 255 255 / 0.4);
  text-decoration: none;
  transition: color var(--transition-fast);
}
.footer-legal__link:hover { color: var(--gold-light); }
</style>
