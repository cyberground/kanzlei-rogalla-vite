---
// forderung.astro — Forderungsmanagement Service Page
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Forderungsmanagement – Offene Rechnungen durchsetzen | Kanzlei Rogalla"
  description="Professionelles Forderungsmanagement: Mahnverfahren, Inkasso, Zwangsvollstreckung. Kanzlei Rogalla holt Ihre offenen Forderungen ein."
>
  <Header slot="header" />

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="page-hero" aria-label="Einleitung Forderungsmanagement">
    <div class="page-hero__bg" aria-hidden="true"></div>
    <div class="container page-hero__inner">
      <div class="page-hero__content animate-fade-in-up">
        <nav class="breadcrumb" aria-label="Brotkrumennavigation">
          <div class="breadcrumb__item">
            <a href="/">Home</a>
            <svg class="breadcrumb__separator" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
          <div class="breadcrumb__item">
            <a href="/services">Leistungen</a>
            <svg class="breadcrumb__separator" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
          <div class="breadcrumb__item" aria-current="page">Forderungsmanagement</div>
        </nav>

        <span class="badge badge--white">Forderungsmanagement</span>
        <h1 class="page-hero__headline">
          Ihre Forderungen.<br />
          <em class="page-hero__accent">Unser Einsatz.</em>
        </h1>
        <p class="page-hero__sub">
          Offene Rechnungen kosten Zeit, Nerven und Liquidität. Kanzlei Rogalla setzt Ihre berechtigten
          Ansprüche konsequent und rechtssicher durch – vom außergerichtlichen Mahnverfahren bis zur
          Zwangsvollstreckung.
        </p>
        <div class="page-hero__ctas">
          <a href="/kontakt" class="btn btn-secondary btn--lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.4 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012.31 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            Kostenlose Erstberatung
          </a>
          <a href="tel:+4966317580179" class="btn btn-ghost btn--lg">
            +49 6631 / 758 017 9
          </a>
        </div>

        <div class="page-hero__stats">
          <div class="hero-stat">
            <span class="hero-stat__num">95%</span>
            <span class="hero-stat__label">Erfolgsquote außergerichtlich</span>
          </div>
          <div class="hero-stat__divider" aria-hidden="true"></div>
          <div class="hero-stat">
            <span class="hero-stat__num">20+</span>
            <span class="hero-stat__label">Jahre Erfahrung</span>
          </div>
          <div class="hero-stat__divider" aria-hidden="true"></div>
          <div class="hero-stat">
            <span class="hero-stat__num">3</span>
            <span class="hero-stat__label">Standorte in Hessen</span>
          </div>
        </div>
      </div>
    </div>
    <div class="page-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"><path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#f9fafb"/></svg>
    </div>
  </section>

  <!-- ============================================================
       SERVICES
       ============================================================ -->
  <section class="section-padding" aria-labelledby="leistungen-forderung">
    <div class="container">
      <div class="section-intro animate-fade-in-up">
        <span class="section-eyebrow">Unsere Leistungen</span>
        <h2 id="leistungen-forderung">Forderungsmanagement aus einer Hand</h2>
        <p class="section-lead">
          Von der ersten Mahnung bis zur Vollstreckung – wir verfolgen Ihre Forderungen konsequent
          und mit allen rechtlichen Mitteln, die das deutsche Recht bietet.
        </p>
      </div>

      <div class="services-grid">
        <article class="service-card animate-fade-in-up">
          <div class="service-card__icon" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
          </div>
          <h3 class="service-card__title">Außergerichtliches Mahnverfahren</h3>
          <p class="service-card__text">
            Ein professionelles anwaltliches Mahnschreiben erzielt in der Praxis deutlich bessere
            Ergebnisse als hausinterne Mahnungen. Wir formulieren rechtssichere Mahnbriefe, setzen
            klare Fristen und kommunizieren direkt mit dem Schuldner – diskret, aber bestimmt.
          </p>
          <ul class="service-card__list">
            <li>Anwaltliche Mahnschreiben mit Rechtswirkung</li>
            <li>Klare Fristen und Konsequenzen</li>
            <li>Außergerichtliche Zahlungsvereinbarungen</li>
            <li>Ratenzahlungsvereinbarungen aushandeln</li>
          </ul>
        </article>

        <article class="service-card animate-fade-in-up">
          <div class="service-card__icon" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3v18M3 9l9-6 9 6M5 19h14"/>
            </svg>
          </div>
          <h3 class="service-card__title">Gerichtliches Mahnverfahren & Inkasso</h3>
          <p class="service-card__text">
            Zahlt der Schuldner trotz Mahnung nicht, beantragen wir beim zuständigen Mahngericht
            einen Mahnbescheid. Wird kein Widerspruch eingelegt, erhalten Sie schnell einen
            vollstreckbaren Titel – die Grundlage für weitere Maßnahmen.
          </p>
          <ul class="service-card__list">
            <li>Mahnbescheidsantrag beim Amtsgericht</li>
            <li>Vollstreckungsbescheid bei ausbleibendem Widerspruch</li>
            <li>Klage im streitigen Verfahren bei Widerspruch</li>
            <li>Titulierung von Forderungen aller Art</li>
          </ul>
        </article>

        <article class="service-card animate-fade-in-up">
          <div class="service-card__icon" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
              <path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/>
            </svg>
          </div>
          <h3 class="service-card__title">Zwangsvollstreckung</h3>
          <p class="service-card__text">
            Mit einem vollstreckbaren Titel in der Hand können wir direkt in das Vermögen des Schuldners
            vollstrecken. Wir koordinieren alle Vollstreckungsmaßnahmen und wählen die wirksamste
            Strategie – je nach Vermögenslage des Schuldners.
          </p>
          <ul class="service-card__list">
            <li>Lohn- und Gehaltspfändung</li>
            <li>Kontopfändung (Pfändungs- und Überweisungsbeschluss)</li>
            <li>Sachpfändung durch den Gerichtsvollzieher</li>
            <li>Immobilienvollstreckung</li>
          </ul>
        </article>

        <article class="service-card animate-fade-in-up">
          <div class="service-card__icon" aria-hidden="true">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </div>
          <h3 class="service-card__title">Schuldnerermittlung</h3>
          <p class="service-card__text">
            Kennen Sie die aktuelle Adresse oder Vermögenslage des Schuldners nicht? Wir ermitteln
            Aufenthaltsadressen und Vermögensverhältnisse auf legalem Weg – damit Sie wissen, ob
            eine Vollstreckung aussichtsreich ist, bevor Kosten entstehen.
          </p>
          <ul class="service-card__list">
            <li>Anfragen beim Einwohnermeldeamt</li>
            <li>Einholen der Vermögensauskunft</li>
            <li>Prüfung auf Insolvenzverfahren</li>
            <li>Bewertung der Vollstreckungsaussichten</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PROCESS STEPS
       ============================================================ -->
  <section class="section-padding bg-navy-deep" aria-labelledby="ablauf-forderung">
    <div class="container">
      <div class="section-intro animate-fade-in-up">
        <span class="section-eyebrow section-eyebrow--light">Unser Vorgehen</span>
        <h2 id="ablauf-forderung" style="color: var(--white);">Von der Forderung zum Geld</h2>
        <p class="section-lead" style="color: rgb(255 255 255 / 0.7);">
          Wir gehen strukturiert vor – schnell, kosteneffizient und immer mit dem Ziel, Ihre
          Forderung tatsächlich einzutreiben.
        </p>
      </div>

      <div class="process-light">
        <div class="process-light__step animate-fade-in-up">
          <div class="process-light__num">1</div>
          <div class="process-light__content">
            <h3>Analyse der Forderung</h3>
            <p>Wir prüfen Ihre Unterlagen, die Rechtslage und die Erfolgsaussichten – schnell und unkompliziert. Schon in der Erstberatung erfahren Sie, welches Vorgehen am erfolgversprechendsten ist.</p>
          </div>
        </div>

        <div class="process-light__step animate-fade-in-up">
          <div class="process-light__num">2</div>
          <div class="process-light__content">
            <h3>Außergerichtliche Mahnung</h3>
            <p>In vielen Fällen genügt ein anwaltliches Mahnschreiben. Der Schuldner zahlt, um ein Gerichtsverfahren zu vermeiden. Wir setzen dabei auf klare Kommunikation und realistische Fristen.</p>
          </div>
        </div>

        <div class="process-light__step animate-fade-in-up">
          <div class="process-light__num">3</div>
          <div class="process-light__content">
            <h3>Gerichtlicher Titel</h3>
            <p>Zahlt der Schuldner nicht freiwillig, beantragen wir Mahnbescheid oder klagen beim zuständigen Gericht. Mit dem Vollstreckungstitel in der Hand stehen Ihnen alle Türen offen.</p>
          </div>
        </div>

        <div class="process-light__step animate-fade-in-up">
          <div class="process-light__num">4</div>
          <div class="process-light__content">
            <h3>Zwangsvollstreckung</h3>
            <p>Mit dem Vollstreckungstitel strecken wir in das pfändbare Vermögen des Schuldners. Wir wählen die effektivste Maßnahme – Lohnpfändung, Kontopfändung oder Sachpfändung.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       WHY US
       ============================================================ -->
  <section class="section-padding" aria-labelledby="warum-rogalla-forderung">
    <div class="container">
      <div class="section-intro animate-fade-in-up">
        <span class="section-eyebrow">Warum Kanzlei Rogalla</span>
        <h2 id="warum-rogalla-forderung">Ihr Vorteil – unser Engagement</h2>
      </div>

      <div class="why-grid">
        <div class="why-item animate-fade-in-up">
          <div class="why-item__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <div>
            <h3 class="why-item__title">Keine Kosten ohne Erfolg</h3>
            <p class="why-item__text">Wir prüfen in der Erstberatung kostenlos, ob Ihre Forderung durchsetzbar ist, und informieren Sie transparent über anfallende Kosten.</p>
          </div>
        </div>

        <div class="why-item animate-fade-in-up">
          <div class="why-item__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <h3 class="why-item__title">Schnelles Handeln</h3>
            <p class="why-item__text">Jeder Tag zählt bei der Forderungsdurchsetzung. Wir handeln sofort und halten Sie kontinuierlich über den Fortschritt informiert.</p>
          </div>
        </div>

        <div class="why-item animate-fade-in-up">
          <div class="why-item__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <div>
            <h3 class="why-item__title">Persönliche Betreuung</h3>
            <p class="why-item__text">Sie sprechen immer direkt mit Rechtsanwältin Rogalla oder einem ihrer Mitarbeiter – keine anonymen Callcenter, keine wechselnden Sachbearbeiter.</p>
          </div>
        </div>

        <div class="why-item animate-fade-in-up">
          <div class="why-item__icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <h3 class="why-item__title">Rechtssichere Durchsetzung</h3>
            <p class="why-item__text">Alle Schritte werden vollständig dokumentiert und rechtskonform durchgeführt – damit Ihr Anspruch nicht an Formalitäten scheitert.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA SECTION
       ============================================================ -->
  <section class="cta-section animate-fade-in-up" aria-label="Beratung anfragen">
    <div class="container">
      <div class="cta-box">
        <div class="cta-box__content">
          <span class="section-eyebrow section-eyebrow--light">Jetzt handeln</span>
          <h2 class="cta-box__title">Lassen Sie Ihre Forderungen nicht verfallen</h2>
          <p class="cta-box__text">
            Forderungen verjähren – handeln Sie rechtzeitig. Rufen Sie uns an oder nutzen Sie
            unser Kontaktformular. Die Erstberatung ist kostenlos und unverbindlich.
          </p>
        </div>
        <div class="cta-box__actions">
          <a href="/kontakt" class="btn btn-secondary btn--lg">Jetzt Beratung anfragen</a>
          <a href="tel:+4966317580179" class="btn btn-outline-light btn--lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.4 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012.31 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            +49 6631 / 758 017 9
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
/* ============================================================
   PAGE HERO
   ============================================================ */
.page-hero {
  position: relative;
  background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 60%, var(--navy-mid) 100%);
  padding-block: var(--space-20) calc(var(--space-20) + 40px);
  overflow: hidden;
}

.page-hero__bg {
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(ellipse at 80% 20%, rgb(156 132 102 / 0.12) 0%, transparent 60%),
    radial-gradient(ellipse at 10% 80%, rgb(204 171 113 / 0.07) 0%, transparent 50%);
  pointer-events: none;
}

.page-hero__inner {
  position: relative;
  z-index: 1;
}

.page-hero__content {
  max-width: 760px;
}

.page-hero__content .breadcrumb {
  margin-bottom: var(--space-6);
  color: rgb(255 255 255 / 0.55);
}

.page-hero__content .breadcrumb a {
  color: rgb(255 255 255 / 0.55);
  transition: color var(--transition-fast);
}

.page-hero__content .breadcrumb a:hover {
  color: var(--gold-light);
}

.page-hero__content .breadcrumb__separator {
  color: rgb(255 255 255 / 0.3);
}

.page-hero__content .badge {
  margin-bottom: var(--space-5);
}

.page-hero__headline {
  font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-5xl));
  font-weight: var(--font-weight-extrabold);
  color: var(--white);
  line-height: 1.1;
  letter-spacing: var(--letter-spacing-tight);
  margin-bottom: var(--space-6);
}

.page-hero__accent {
  color: var(--gold-light);
  font-style: normal;
}

.page-hero__sub {
  font-size: var(--font-size-lg);
  color: rgb(255 255 255 / 0.78);
  line-height: var(--line-height-relaxed);
  max-width: 60ch;
  margin-bottom: var(--space-8);
}

.page-hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  align-items: center;
  margin-bottom: var(--space-10);
}

.page-hero__stats {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-5);
  padding-top: var(--space-8);
  border-top: 1px solid rgb(255 255 255 / 0.15);
}

.hero-stat {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.hero-stat__num {
  font-size: var(--font-size-3xl);
  font-weight: var(--font-weight-extrabold);
  color: var(--gold-light);
  line-height: 1;
}

.hero-stat__label {
  font-size: var(--font-size-xs);
  color: rgb(255 255 255 / 0.6);
  font-weight: var(--font-weight-medium);
  letter-spacing: var(--letter-spacing-wide);
}

.hero-stat__divider {
  width: 1px;
  height: 40px;
  background-color: rgb(255 255 255 / 0.2);
}

.page-hero__wave {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  line-height: 0;
}

.page-hero__wave svg {
  width: 100%;
  height: 60px;
}

/* Ghost outline light button for dark backgrounds */
.btn-ghost {
  background-color: rgb(255 255 255 / 0.1);
  color: var(--white);
  border: 2px solid rgb(255 255 255 / 0.3);
}

.btn-ghost:hover {
  background-color: rgb(255 255 255 / 0.2);
  border-color: rgb(255 255 255 / 0.6);
  color: var(--white);
}

.btn-outline-light {
  background-color: transparent;
  color: var(--white);
  border-color: rgb(255 255 255 / 0.45);
}

.btn-outline-light:hover {
  background-color: rgb(255 255 255 / 0.12);
  border-color: rgb(255 255 255 / 0.7);
  color: var(--white);
}

/* ============================================================
   SECTION INTRO
   ============================================================ */
.section-intro {
  text-align: center;
  max-width: 680px;
  margin: 0 auto var(--space-12);
}

.section-eyebrow {
  display: inline-block;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  letter-spacing: var(--letter-spacing-widest);
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: var(--space-3);
}

.section-eyebrow--light { color: var(--gold-light); }

.section-intro h2 {
  margin-bottom: var(--space-4);
}

.section-lead {
  font-size: var(--font-size-lg);
  color: var(--text-light);
  line-height: var(--line-height-relaxed);
  max-width: 60ch;
  margin: 0 auto;
}

/* ============================================================
   SERVICES GRID
   ============================================================ */
.services-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-6);
}

@media (min-width: 768px) {
  .services-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

.service-card {
  background: var(--white);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-2xl);
  padding: var(--space-8);
  box-shadow: var(--shadow-sm);
  transition: box-shadow var(--transition-base), transform var(--transition-base);
  border-top: 3px solid var(--gold);
}

.service-card:hover {
  box-shadow: var(--shadow-xl);
  transform: translateY(-3px);
}

.service-card__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 60px;
  height: 60px;
  border-radius: var(--radius-xl);
  background-color: var(--gold-xpale);
  color: var(--gold);
  margin-bottom: var(--space-5);
}

.service-card__title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--navy);
  margin-bottom: var(--space-4);
}

.service-card__text {
  color: var(--text-light);
  line-height: var(--line-height-relaxed);
  margin-bottom: var(--space-5);
  max-width: none;
}

.service-card__list {
  list-style: none;
  padding: 0;
  border-top: 1px solid var(--border-light);
  padding-top: var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.service-card__list li {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  font-size: var(--font-size-sm);
  color: var(--text-light);
}

.service-card__list li::before {
  content: '';
  display: inline-block;
  flex-shrink: 0;
  width: 6px;
