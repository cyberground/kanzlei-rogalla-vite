---
// services/index.astro — Leistungen Overview Page
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const services = [
  {
    slug: '/services/insolvenz',
    badge: 'Insolvenzrecht',
    title: 'Insolvenz & Restschuldbefreiung',
    tagline: 'Neustart in 3 Jahren',
    description: 'Sie sind überschuldet und sehen keinen Ausweg? Das Insolvenzverfahren eröffnet Ihnen einen rechtlich garantierten Neustart. Nach 3 Jahren Wohlverhaltensphase werden alle verbliebenen Schulden vollständig erlassen.',
    features: ['Privatinsolvenz & Verbraucherinsolvenz', 'Regelinsolvenz für Unternehmen', 'Außergerichtlicher Schuldenbereinigungsplan', 'Begleitung bis zur Restschuldbefreiung'],
    color: 'gold',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M3 9l9-6 9 6M5 19h14M3 14l4-5 4 5M13 14l4-5 4 5"/></svg>`,
  },
  {
    slug: '/services/forderung',
    badge: 'Forderungsmanagement',
    title: 'Forderungen durchsetzen',
    tagline: 'Ihre Ansprüche. Unser Einsatz.',
    description: 'Offene Rechnungen und nicht zahlende Schuldner kosten Sie bares Geld. Wir treiben Ihre Forderungen professionell ein – vom anwaltlichen Mahnschreiben bis zur Zwangsvollstreckung.',
    features: ['Außergerichtliche Mahnung', 'Mahnbescheid und gerichtliches Inkasso', 'Zwangsvollstreckung', 'Schuldnerermittlung'],
    color: 'navy',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  },
  {
    slug: '/services/vorsorge-nachlass',
    badge: 'Vorsorge & Nachlass',
    title: 'Vorsorge & Nachlass',
    tagline: 'Für sich und Ihre Liebsten.',
    description: 'Testament, Erbvertrag, Vorsorgevollmacht und Patientenverfügung – wir helfen Ihnen, Ihre Wünsche rechtssicher zu dokumentieren und Ihre Familie vor Unsicherheit und Streit zu schützen.',
    features: ['Testament & Erbvertrag', 'Vorsorgevollmacht', 'Patientenverfügung', 'Nachlassberatung & Erbschaftsrecht'],
    color: 'gold',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    slug: '/services/erbrecht',
    badge: 'Erbrecht',
    title: 'Erbrecht & Nachlassstreitigkeiten',
    tagline: 'Ihr Erbe in guten Händen.',
    description: 'Von der Testamentserstellung bis zur Beilegung eines Erbstreits: Kanzlei Rogalla ist Ihr erfahrener Partner in allen erbrechtlichen Fragen – für Erblasser, Erben und Pflichtteilsberechtigte.',
    features: ['Testamentserstellung & Erbvertrag', 'Pflichtteilsrecht', 'Erbstreitigkeiten beilegen', 'Testamentsvollstreckung & Nachlassabwicklung'],
    color: 'navy',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
  },
];
---

<Layout
  title="Leistungen – Insolvenzrecht, Erbrecht & Forderungsmanagement | Kanzlei Rogalla"
  description="Kanzlei Rogalla bietet umfassende Rechtsberatung in Insolvenzrecht, Forderungsmanagement, Vorsorge & Nachlass sowie Erbrecht. Persönliche Beratung in Alsfeld, Gießen und Offenbach."
>
  <Header slot="header" />

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="page-hero" aria-label="Leistungsübersicht">
    <div class="page-hero__bg" aria-hidden="true"></div>
    <div class="container page-hero__inner">
      <div class="page-hero__content animate-fade-in-up">
        <span class="badge badge--white">Unsere Leistungen</span>
        <h1 class="page-hero__headline">
          Rechtliche Kompetenz –<br />
          <em class="page-hero__accent">wo Sie sie brauchen.</em>
        </h1>
        <p class="page-hero__sub">
          Kanzlei Rogalla ist spezialisiert auf Insolvenzrecht, Forderungsmanagement, Erbrecht und
          Vorsorge. Rechtsanwältin Christina Rogalla berät Sie mit über 20 Jahren Erfahrung –
          persönlich, direkt und ohne Umwege.
        </p>

        <div class="page-hero__trust">
          <div class="trust-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Kostenlose Erstberatung
          </div>
          <span class="trust-sep" aria-hidden="true">|</span>
          <div class="trust-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            20+ Jahre Erfahrung
          </div>
          <span class="trust-sep" aria-hidden="true">|</span>
          <div class="trust-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            3 Standorte in Hessen
          </div>
        </div>
      </div>
    </div>
    <div class="page-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"><path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#f9fafb"/></svg>
    </div>
  </section>

  <!-- ============================================================
       SERVICE CARDS
       ============================================================ -->
  <section class="section-padding" aria-labelledby="leistungen-uebersicht">
    <div class="container">
      <div class="sr-only" id="leistungen-uebersicht">Leistungsübersicht</div>

      <div class="services-overview">
        {services.map((service, i) => (
          <article class={`service-overview-card service-overview-card--${service.color} animate-fade-in-up`}>
            <div class="service-overview-card__inner">
              <div class="service-overview-card__left">
                <div class="service-overview-card__icon" aria-hidden="true" set:html={service.icon}></div>
                <div class="service-overview-card__meta">
                  <span class={`badge badge--${service.color === 'gold' ? 'gold' : 'navy'}`}>{service.badge}</span>
                  <h2 class="service-overview-card__title">{service.title}</h2>
                  <p class="service-overview-card__tagline">{service.tagline}</p>
                  <p class="service-overview-card__desc">{service.description}</p>
                  <a href={service.slug} class={`btn ${service.color === 'gold' ? 'btn-secondary' : 'btn-primary'} btn--lg service-overview-card__cta`}>
                    Mehr erfahren
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                  </a>
                </div>
              </div>
              <div class="service-overview-card__features">
                <p class="service-overview-card__features-label">Was wir bieten:</p>
                <ul class="service-overview-card__list">
                  {service.features.map(f => (
                    <li>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                      {f}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       TRUST SECTION
       ============================================================ -->
  <section class="section-padding bg-light" aria-labelledby="warum-rogalla-overview">
    <div class="container">
      <div class="section-intro animate-fade-in-up">
        <span class="section-eyebrow">Warum Kanzlei Rogalla</span>
        <h2 id="warum-rogalla-overview">Ihr Vorteil – unsere Haltung</h2>
      </div>

      <div class="trust-grid">
        <div class="trust-card animate-fade-in-up">
          <div class="trust-card__icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <h3 class="trust-card__title">Persönliche Beratung</h3>
          <p class="trust-card__text">Sie sprechen immer direkt mit Rechtsanwältin Rogalla. Keine Weiterleitungen, kein Callcenter – nur persönliche, engagierte Rechtsberatung.</p>
        </div>

        <div class="trust-card animate-fade-in-up">
          <div class="trust-card__icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="trust-card__title">20+ Jahre Erfahrung</h3>
          <p class="trust-card__text">Seit über 20 Jahren berät Rechtsanwältin Rogalla in ihren Spezialgebieten. Diese Erfahrung kommt Ihnen direkt zugute.</p>
        </div>

        <div class="trust-card animate-fade-in-up">
          <div class="trust-card__icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3 class="trust-card__title">3 Standorte in Hessen</h3>
          <p class="trust-card__text">Mit Standorten in Alsfeld, Gießen und Offenbach sind wir in der Region für Sie erreichbar – nah, verlässlich, vertraut.</p>
        </div>

        <div class="trust-card animate-fade-in-up">
          <div class="trust-card__icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3 class="trust-card__title">Kostenlose Erstberatung</h3>
          <p class="trust-card__text">In der kostenlosen Erstberatung klären wir Ihre Situation, zeigen Handlungsoptionen auf und informieren Sie transparent über anfallende Kosten.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA
       ============================================================ -->
  <section class="cta-section animate-fade-in-up" aria-label="Beratung anfragen">
    <div class="container">
      <div class="cta-box">
        <div class="cta-box__content">
          <span class="section-eyebrow section-eyebrow--light">Erste Schritte</span>
          <h2 class="cta-box__title">Welche Frage beschäftigt Sie?</h2>
          <p class="cta-box__text">
            Erzählen Sie uns von Ihrer Situation – wir hören zu und beraten Sie ehrlich.
            Erstberatung kostenlos, per Telefon oder in einem unserer Büros.
          </p>
        </div>
        <div class="cta-box__actions">
          <a href="/kontakt" class="btn btn-secondary btn--lg">Jetzt Kontakt aufnehmen</a>
          <a href="tel:+4966317580179" class="btn btn-outline-light btn--lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.4 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012.31 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            +49 6631 / 758 017 9
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
/* ============================================================
   PAGE HERO
   ============================================================ */
.page-hero {
  position: relative;
  background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 60%, var(--navy-mid) 100%);
  padding-block: var(--space-20) calc(var(--space-20) + 40px);
  overflow: hidden;
}

.page-hero__bg {
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(ellipse at 80% 20%, rgb(156 132 102 / 0.12) 0%, transparent 60%),
    radial-gradient(ellipse at 10% 80%, rgb(204 171 113 / 0.07) 0%, transparent 50%);
  pointer-events: none;
}

.page-hero__inner { position: relative; z-index: 1; }
.page-hero__content { max-width: 760px; }

.page-hero__content .badge { margin-bottom: var(--space-5); }

.page-hero__headline {
  font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-5xl));
  font-weight: var(--font-weight-extrabold);
  color: var(--white);
  line-height: 1.1;
  letter-spacing: var(--letter-spacing-tight);
  margin-bottom: var(--space-6);
}

.page-hero__accent { color: var(--gold-light); font-style: normal; }

.page-hero__sub {
  font-size: var(--font-size-lg);
  color: rgb(255 255 255 / 0.78);
  line-height: var(--line-height-relaxed);
  max-width: 60ch;
  margin-bottom: var(--space-8);
}

.page-hero__trust {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-5);
}

.trust-item {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: rgb(255 255 255 / 0.7);
}

.trust-item svg { color: var(--gold-light); flex-shrink: 0; }

.trust-sep {
  color: rgb(255 255 255 / 0.25);
  font-size: var(--font-size-sm);
}

.page-hero__wave {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  line-height: 0;
}

.page-hero__wave svg { width: 100%; height: 60px; }

/* ============================================================
   SECTION INTRO
   ============================================================ */
.section-intro {
  text-align: center;
  max-width: 680px;
  margin: 0 auto var(--space-12);
}

.section-eyebrow {
  display: inline-block;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  letter-spacing: var(--letter-spacing-widest);
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: var(--space-3);
}

.section-eyebrow--light { color: var(--gold-light); }

.section-intro h2 { margin-bottom: var(--space-4); }

/* ============================================================
   SERVICES OVERVIEW
   ============================================================ */
.services-overview {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

.service-overview-card {
  background: var(--white);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-3xl);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  transition: box-shadow var(--transition-base), transform var(--transition-base);
}

.service-overview-card:hover {
  box-shadow: var(--shadow-xl);
  transform: translateY(-3px);
}

.service-overview-card--gold {
  border-top: 4px solid var(--gold);
}

.service-overview-card--navy {
  border-top: 4px solid var(--navy);
}

.service-overview-card__inner {
  display: flex;
  flex-direction: column;
  gap: 0;
}

@media (min-width: 768px) {
  .service-overview-card__inner {
    flex-direction: row;
  }
}

.service-overview-card__left {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
  padding: var(--space-8);
  flex: 1;
}

@media (min-width: 768px) {
  .service-overview-card__left {
    flex-direction: row;
    align-items: flex-start;
  }
}

.service-overview-card__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68px;
  height: 68px;
  border-radius: var(--radius-xl);
  background-color: var(--gold-xpale);
  color: var(--gold);
  flex-shrink: 0;
}

.service-overview-card--navy .service-overview-card__icon {
  background-color: rgb(2 58 81 / 0.07);
  color: var(--navy);
}

.service-overview-card__meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.service-overview-card__title {
  font-size: clamp(var(--font-size-xl), 2.5vw, var(--font-size-3xl));
  font-weight: var(--font-weight-bold);
  color: var(--navy);
}

.service-overview-card__tagline {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--gold);
  text-transform: uppercase;
  letter-spacing: var(--letter-spacing-wide);
  margin: 0;
  max-width: none;
}

.service-overview-card__desc {
  color: var(--text-light);
  line-height: var(--line-height-relaxed);
  max-width: 60ch;
}

.service-overview-card__cta { align-self: flex-start; margin-top: var(--space-2); }

.service-overview-card__features {
  padding: var(--space-8);
  background-color: var(--bg);
  border-top: 1px solid var(--border-light);
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  min-width: 260px;
}

@media (min-width: 768px) {
  .service-overview-card__features {
    border-top: none;
    border-left: 1px solid var(--border-light);
  }
}

.service-overview-card__features-label {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  letter-spacing: var(--letter-spacing-widest);
  text-transform: uppercase;
  color: var(--text-muted);
  margin: 0;
  max-width: none;
}

.service-overview-card__list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.service-overview-card__list li {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  font-size: var(--font-size-sm);
  color: var(--text-light);
  line-height: var(--line-height-snug);
}

.service-overview-card__list li svg {
  color: var(--gold);
  flex-shrink: 0;
  margin-top: 2px;
}

/* ============================================================
   TRUST GRID
   ============================================================ */
.trust-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-6);
}

@media (min-width: 640px) {
  .trust-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (min-width: 1024px) {
  .trust-grid { grid-template-columns: repeat(4, 1fr); }
}

.trust-card {
  background: var(--white);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-xl);
  padding: var(--space-6);
  box-shadow: var(--shadow-xs);
  transition: box-shadow var(--transition-base), transform var(--transition-base);
}

.trust-card:hover {
  box-shadow: var(--shadow-lg);
  transform: translateY(-3px);
}

.trust-card__icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 52px;
  height: 52px;
  border-radius: var(--radius-lg);
  background-color: var(--gold-xpale);
  color: var(--gold);
  margin-bottom: var(--space-5);
}

.trust-card__title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--navy);
  margin-bottom: var(--space-3);
}

.trust-card__text {
  font-size: var(--font-size-sm);
  color: var(--text-light);
  line-height: var(--line-height-relaxed);
  max-width: none;
}

/* ============================================================
   CTA SECTION
   ============================================================ */
.cta-section { padding-block: var(--space-16); }

.cta-box {
  background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 100%);
  border-radius: var(--radius-3xl);
  padding: var(--space-12) var(--space-10);
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
  align-items: flex-start;
  position: relative;
  overflow: hidden;
}

.cta-box::before {
  content: '';
  position: absolute;
  top: -60px;
  right: -60px;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  background: radial-gradient(circle, rgb(204 171 113 / 0.15) 0%, transparent 70%);
  pointer-events: none;
}

@media (min-width: 768px) {
  .cta-box {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
}

.cta-box__content { flex: 1; }

.cta-box__title {
  font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-4xl));
  font-weight: var(--font-weight-bold);
  color: var(--white);
  margin-bottom: var(--space-4);
}

.cta-box__text {
  color: rgb(255 255 255 / 0.72);
  line-height: var(--line-height-relaxed);
  max-width: 52ch;
}

.cta-box__actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  flex-shrink: 0;
}

@media (min-width: 640px) {
  .cta-box__actions {
    flex-direction: row;
    align-items: center;
  }
}

.btn-outline-light {
  background-color: transparent;
  color: var(--white);
  border-color: rgb(255 255 255 / 0.45);
}

.btn-outline-light:hover {
  background-color: rgb(255 255 255 / 0.12);
  border-color: rgb(255 255 255 / 0.7);
