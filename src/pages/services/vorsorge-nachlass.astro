---
// vorsorge-nachlass.astro — Vorsorge & Nachlass Service Page
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Vorsorge & Nachlass – Testament, Erbschaft, Patientenverfügung | Kanzlei Rogalla"
  description="Vorsorgevollmacht, Testament, Erbschaft und Patientenverfügung – Kanzlei Rogalla gestaltet Ihre Vorsorge rechtssicher."
>
  <Header slot="header" />

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="page-hero" aria-label="Einleitung Vorsorge & Nachlass">
    <div class="page-hero__bg" aria-hidden="true"></div>
    <div class="container page-hero__inner">
      <div class="page-hero__content animate-fade-in-up">
        <nav class="breadcrumb" aria-label="Brotkrumennavigation">
          <div class="breadcrumb__item">
            <a href="/">Home</a>
            <svg class="breadcrumb__separator" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
          <div class="breadcrumb__item">
            <a href="/services">Leistungen</a>
            <svg class="breadcrumb__separator" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
          <div class="breadcrumb__item" aria-current="page">Vorsorge & Nachlass</div>
        </nav>

        <span class="badge badge--white">Vorsorge & Nachlass</span>
        <h1 class="page-hero__headline">
          Vorsorgen –<br />
          <em class="page-hero__accent">für sich und Ihre Liebsten.</em>
        </h1>
        <p class="page-hero__sub">
          Niemand denkt gerne an Krankheit oder den eigenen Tod. Doch wer rechtzeitig vorsorgt,
          schützt seine Familie vor Unsicherheit und Streit – und stellt sicher, dass die eigenen
          Wünsche auch dann respektiert werden, wenn man selbst nicht mehr sprechen kann.
        </p>
        <div class="page-hero__ctas">
          <a href="/kontakt" class="btn btn-secondary btn--lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.4 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012.31 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            Kostenlose Erstberatung
          </a>
          <a href="tel:+4966317580179" class="btn btn-ghost btn--lg">
            +49 6631 / 758 017 9
          </a>
        </div>
      </div>
    </div>
    <div class="page-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"><path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#f9fafb"/></svg>
    </div>
  </section>

  <!-- ============================================================
       WHY ACT NOW
       ============================================================ -->
  <section class="section-padding" aria-labelledby="warum-jetzt-vorsorge">
    <div class="container">
      <div class="section-intro animate-fade-in-up">
        <span class="section-eyebrow">Warum jetzt handeln?</span>
        <h2 id="warum-jetzt-vorsorge">3 Gründe für rechtzeitige Vorsorge</h2>
        <p class="section-lead">
          Vorsorge ist keine Aufgabe für morgen. Diese drei Gründe zeigen, warum Sie heute handeln sollten.
        </p>
      </div>

      <div class="reasons-grid">
        <div class="reason-card animate-fade-in-up">
          <div class="reason-card__num" aria-hidden="true">01</div>
          <h3 class="reason-card__title">Selbstbestimmung erhalten</h3>
          <p class="reason-card__text">
            Ohne Vorsorgevollmacht kann niemand – auch nicht der Ehepartner oder die Kinder – nach
            einem Unfall oder einer plötzlichen Erkrankung für Sie handeln. Das Gericht bestellt
            dann einen gesetzlichen Betreuer, dessen Entscheidungen Ihren eigenen Wünschen möglicherweise
            widersprechen. Eine Vorsorgevollmacht stellt sicher, dass eine Person Ihres Vertrauens
            in Ihrem Sinne handelt.
          </p>
        </div>

        <div class="reason-card animate-fade-in-up">
          <div class="reason-card__num" aria-hidden="true">02</div>
          <h3 class="reason-card__title">Familie vor Streit schützen</h3>
          <p class="reason-card__text">
            Wer kein Testament hinterlässt, hinterlässt die gesetzliche Erbfolge – die oft nicht dem
            entspricht, was der Erblasser gewollt hätte. Besonders in Patchworkfamilien, bei unverheirateten
            Paaren oder bei ungleich verteiltem Vermögen sorgt das für Konflikte. Ein gut formuliertes
            Testament schützt Ihre Familie vor jahrelangem Erbstreit.
          </p>
        </div>

        <div class="reason-card animate-fade-in-up">
          <div class="reason-card__num" aria-hidden="true">03</div>
          <h3 class="reason-card__title">Steuern legal minimieren</h3>
          <p class="reason-card__text">
            Durch vorausschauende Nachlassplanung lassen sich Erbschaftssteuern erheblich reduzieren.
            Schenkungen zu Lebzeiten, Nießbrauchregelungen und testamentarische Gestaltungen können
            die Steuerlast Ihrer Erben drastisch senken – legal und sicher.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SERVICES
       ============================================================ -->
  <section class="section-padding bg-light" aria-labelledby="leistungen-vorsorge">
    <div class="container">
      <div class="section-intro animate-fade-in-up">
        <span class="section-eyebrow">Unsere Leistungen</span>
        <h2 id="leistungen-vorsorge">Vorsorge & Nachlass – was wir für Sie tun</h2>
      </div>

      <div class="vorsorge-grid">
        <article class="vorsorge-card animate-fade-in-up">
          <div class="vorsorge-card__header">
            <div class="vorsorge-card__icon" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="12" y1="12" x2="8" y2="12"/>
                <line x1="12" y1="16" x2="8" y2="16"/>
              </svg>
            </div>
            <h3 class="vorsorge-card__title">Testament</h3>
          </div>
          <p class="vorsorge-card__text">
            Ein handschriftliches Testament kann selbst verfasst werden – doch Formfehler oder
            unklare Formulierungen können zur Nichtigkeit oder zu Auslegungsstreitigkeiten führen.
            Wir erstellen Ihr Testament rechtssicher und exakt nach Ihren Wünschen. Auch notarielle
            Testamente können wir vorbereiten und koordinieren.
          </p>
          <ul class="vorsorge-card__list">
            <li>Handschriftliches oder notarielles Testament</li>
            <li>Berücksichtigung von Pflichtteilen</li>
            <li>Regelungen für Patchworkfamilien</li>
            <li>Testamentarische Auflagen und Bedingungen</li>
          </ul>
        </article>

        <article class="vorsorge-card animate-fade-in-up">
          <div class="vorsorge-card__header">
            <div class="vorsorge-card__icon" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                <path d="M16 3.13a4 4 0 010 7.75"/>
              </svg>
            </div>
            <h3 class="vorsorge-card__title">Erbvertrag</h3>
          </div>
          <p class="vorsorge-card__text">
            Der Erbvertrag geht einen Schritt weiter als das Testament: Er ist notariell zu beurkunden
            und bindet beide Parteien. Besonders für Ehegatten, Lebenspartner und Geschäftspartner
            bietet er rechtliche Sicherheit und Verlässlichkeit. Im Erbvertrag können gegenseitige
            Erbeneinsetzungen verbindlich vereinbart werden.
          </p>
          <ul class="vorsorge-card__list">
            <li>Notariell beurkundeter Vertrag</li>
            <li>Bindungswirkung für beide Parteien</li>
            <li>Ideal für Ehegatten und Lebenspartner</li>
            <li>Geschäftsnachfolge absichern</li>
          </ul>
        </article>

        <article class="vorsorge-card animate-fade-in-up">
          <div class="vorsorge-card__header">
            <div class="vorsorge-card__icon" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <h3 class="vorsorge-card__title">Vorsorgevollmacht</h3>
          </div>
          <p class="vorsorge-card__text">
            Die Vorsorgevollmacht ermächtigt eine Vertrauensperson, in Ihrem Namen zu handeln –
            bei Geschäften, Bankangelegenheiten, Behördengängen und medizinischen Entscheidungen.
            Ohne eine solche Vollmacht kann auch der Ehepartner nicht ohne behördliche Genehmigung
            handeln. Wir gestalten Ihre Vollmacht präzise und rechtssicher.
          </p>
          <ul class="vorsorge-card__list">
            <li>Umfassende oder begrenzte Vollmacht möglich</li>
            <li>Gilt sofort oder ab Eintritt des Bedürfnisses</li>
            <li>Vermeidet behördliche Betreuung</li>
            <li>Kombination mit Patientenverfügung empfohlen</li>
          </ul>
        </article>

        <article class="vorsorge-card animate-fade-in-up">
          <div class="vorsorge-card__header">
            <div class="vorsorge-card__icon" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
              </svg>
            </div>
            <h3 class="vorsorge-card__title">Patientenverfügung</h3>
          </div>
          <p class="vorsorge-card__text">
            Die Patientenverfügung ist Ihre persönliche Anweisung für den Fall, dass Sie nicht mehr
            selbst über medizinische Maßnahmen entscheiden können. Sie legt fest, welche Behandlungen
            Sie wünschen oder ablehnen. Eine rechtlich wirksame Patientenverfügung muss schriftlich
            vorliegen – wir helfen Ihnen, Ihre Wünsche präzise zu formulieren.
          </p>
          <ul class="vorsorge-card__list">
            <li>Schriftliche Festlegung medizinischer Wünsche</li>
            <li>Ablehnung oder Zustimmung zu Behandlungen</li>
            <li>Verbindlich für Ärzte und Pflegepersonal</li>
            <li>Regelmäßige Aktualisierung empfohlen</li>
          </ul>
        </article>

        <article class="vorsorge-card animate-fade-in-up">
          <div class="vorsorge-card__header">
            <div class="vorsorge-card__icon" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
            </div>
            <h3 class="vorsorge-card__title">Erbschaftsrecht & Nachlassberatung</h3>
          </div>
          <p class="vorsorge-card__text">
            Sie haben geerbt und wissen nicht, was nun zu tun ist? Wir beraten Sie zu Annahme oder
            Ausschlagung der Erbschaft, klären offene Schulden des Erblassers, begleiten die Nachlassabwicklung
            und helfen bei der Auseinandersetzung einer Erbengemeinschaft – damit kein Erbe unbeabsichtigt
            für fremde Schulden haftet.
          </p>
          <ul class="vorsorge-card__list">
            <li>Erbschaft annehmen oder ausschlagen</li>
            <li>Nachlassabwicklung und -verwaltung</li>
            <li>Auseinandersetzung der Erbengemeinschaft</li>
            <li>Nachlassinsolvenz bei überschuldetem Nachlass</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA SECTION
       ============================================================ -->
  <section class="cta-section animate-fade-in-up" aria-label="Beratung anfragen">
    <div class="container">
      <div class="cta-box">
        <div class="cta-box__content">
          <span class="section-eyebrow section-eyebrow--light">Jetzt handeln</span>
          <h2 class="cta-box__title">Heute vorsorgen – morgen sicher sein</h2>
          <p class="cta-box__text">
            Es ist nie zu früh für Vorsorge – aber es kann zu spät werden. Vereinbaren Sie jetzt
            Ihre kostenlose Erstberatung mit Rechtsanwältin Christina Rogalla.
          </p>
        </div>
        <div class="cta-box__actions">
          <a href="/kontakt" class="btn btn-secondary btn--lg">Termin vereinbaren</a>
          <a href="tel:+4966317580179" class="btn btn-outline-light btn--lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.4 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012.31 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            +49 6631 / 758 017 9
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
/* ============================================================
   PAGE HERO
   ============================================================ */
.page-hero {
  position: relative;
  background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 60%, var(--navy-mid) 100%);
  padding-block: var(--space-20) calc(var(--space-20) + 40px);
  overflow: hidden;
}

.page-hero__bg {
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(ellipse at 80% 20%, rgb(156 132 102 / 0.12) 0%, transparent 60%),
    radial-gradient(ellipse at 10% 80%, rgb(204 171 113 / 0.07) 0%, transparent 50%);
  pointer-events: none;
}

.page-hero__inner { position: relative; z-index: 1; }

.page-hero__content { max-width: 760px; }

.page-hero__content .breadcrumb {
  margin-bottom: var(--space-6);
  color: rgb(255 255 255 / 0.55);
}

.page-hero__content .breadcrumb a {
  color: rgb(255 255 255 / 0.55);
  transition: color var(--transition-fast);
}

.page-hero__content .breadcrumb a:hover { color: var(--gold-light); }
.page-hero__content .breadcrumb__separator { color: rgb(255 255 255 / 0.3); }
.page-hero__content .badge { margin-bottom: var(--space-5); }

.page-hero__headline {
  font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-5xl));
  font-weight: var(--font-weight-extrabold);
  color: var(--white);
  line-height: 1.1;
  letter-spacing: var(--letter-spacing-tight);
  margin-bottom: var(--space-6);
}

.page-hero__accent { color: var(--gold-light); font-style: normal; }

.page-hero__sub {
  font-size: var(--font-size-lg);
  color: rgb(255 255 255 / 0.78);
  line-height: var(--line-height-relaxed);
  max-width: 60ch;
  margin-bottom: var(--space-8);
}

.page-hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  align-items: center;
}

.page-hero__wave {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  line-height: 0;
}

.page-hero__wave svg { width: 100%; height: 60px; }

.btn-ghost {
  background-color: rgb(255 255 255 / 0.1);
  color: var(--white);
  border: 2px solid rgb(255 255 255 / 0.3);
}

.btn-ghost:hover {
  background-color: rgb(255 255 255 / 0.2);
  border-color: rgb(255 255 255 / 0.6);
  color: var(--white);
}

.btn-outline-light {
  background-color: transparent;
  color: var(--white);
  border-color: rgb(255 255 255 / 0.45);
}

.btn-outline-light:hover {
  background-color: rgb(255 255 255 / 0.12);
  border-color: rgb(255 255 255 / 0.7);
  color: var(--white);
}

/* ============================================================
   SECTION INTRO
   ============================================================ */
.section-intro {
  text-align: center;
  max-width: 680px;
  margin: 0 auto var(--space-12);
}

.section-eyebrow {
  display: inline-block;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  letter-spacing: var(--letter-spacing-widest);
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: var(--space-3);
}

.section-eyebrow--light { color: var(--gold-light); }

.section-intro h2 { margin-bottom: var(--space-4); }

.section-lead {
  font-size: var(--font-size-lg);
  color: var(--text-light);
  line-height: var(--line-height-relaxed);
  max-width: 60ch;
  margin: 0 auto;
}

/* ============================================================
   REASONS GRID
   ============================================================ */
.reasons-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-6);
}

@media (min-width: 768px) {
  .reasons-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.reason-card {
  background: var(--white);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-2xl);
  padding: var(--space-8);
  box-shadow: var(--shadow-sm);
  transition: box-shadow var(--transition-base), transform var(--transition-base);
  position: relative;
  overflow: hidden;
}

.reason-card:hover {
  box-shadow: var(--shadow-xl);
  transform: translateY(-4px);
}

.reason-card__num {
  font-size: clamp(var(--font-size-4xl), 6vw, 5rem);
  font-weight: var(--font-weight-extrabold);
  color: var(--gold-pale);
  line-height: 1;
  margin-bottom: var(--space-4);
  letter-spacing: var(--letter-spacing-tight);
}

.reason-card__title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--navy);
  margin-bottom: var(--space-4);
}

.reason-card__text {
  color: var(--text-light);
  line-height: var(--line-height-relaxed);
  max-width: none;
}

/* ============================================================
   VORSORGE GRID
   ============================================================ */
.vorsorge-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-6);
}

@media (min-width: 768px) {
  .vorsorge-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

.vorsorge-card {
  background: var(--white);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-2xl);
  padding: var(--space-7);
  box-shadow: var(--shadow-sm);
  transition: box-shadow var(--transition-base), transform var(--transition-base);
}

.vorsorge-card:hover {
  box-shadow: var(--shadow-lg);
  transform: translateY(-3px);
}

.vorsorge-card__header {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  margin-bottom: var(--space-5);
}

.vorsorge-card__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52px;
  height: 52px;
  border-radius: var(--radius-lg);
  background-color: var(--gold-xpale);
  color: var(--gold);
  flex-shrink: 0;
}

.vorsorge-card__title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--navy);
}

.vorsorge-card__text {
  color: var(--text-light);
  line-height: var(--line-height-relaxed);
  margin-bottom: var(--space-5);
  max-width: none;
}

.vorsorge-card__list {
  list-style: none;
  padding: 0;
  border-top: 1px solid var(--border-light);
  padding-top: var(--space-4);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.vorsorge-card__list li {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  font-size: var(--font-size-sm);
  color: var(--text-light);
}

.vorsorge-card__list li::before {
  content: '';
  display: inline-block;
  flex-shrink: 0;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: var(--gold);
  margin-top: 0.55em;
}

/* ============================================================
   CTA SECTION
   ============================================================ */
.cta-section { padding-block: var(--space-16); }

.cta-box {
  background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 100%);
  border-radius: var(--radius-3xl);
  padding: var(--space-12) var(--space-10);
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
  align-items: flex-start;
  position: relative;
  overflow: hidden;
}

.cta-box::before {
  content: '';
  position: absolute;
  top: -60px;
  right: -60px;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  background: radial-gradient(circle, rgb(204 171 113 / 0.15) 0%, transparent 70%);
  pointer-events: none;
}

@media (min-width: 768px) {
  .cta-box {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
}

.cta-box__content { flex: 1; }

.cta-box__title {
  font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-4xl));
  font-weight: var(--font-weight-bold);
  color: var(--white);
  margin-bottom: var(--space-4);
}

.cta-box__text {
