---
// erbrecht.astro — Erbrecht Service Page
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Erbrecht – Testament, Erbstreit & Pflichtteil | Kanzlei Rogalla"
  description="Anwalt für Erbrecht in Alsfeld, Gießen & Offenbach. Testament, Pflichtteil, Erbstreit, Testamentsvollstreckung – persönliche Beratung."
>
  <Header slot="header" />

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="page-hero" aria-label="Einleitung Erbrecht">
    <div class="page-hero__bg" aria-hidden="true"></div>
    <div class="container page-hero__inner">
      <div class="page-hero__content animate-fade-in-up">
        <nav class="breadcrumb" aria-label="Brotkrumennavigation">
          <div class="breadcrumb__item">
            <a href="/">Home</a>
            <svg class="breadcrumb__separator" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
          <div class="breadcrumb__item">
            <a href="/services">Leistungen</a>
            <svg class="breadcrumb__separator" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
          <div class="breadcrumb__item" aria-current="page">Erbrecht</div>
        </nav>

        <span class="badge badge--white">Erbrecht</span>
        <h1 class="page-hero__headline">
          Ihr Erbe in<br />
          <em class="page-hero__accent">guten Händen.</em>
        </h1>
        <p class="page-hero__sub">
          Ein Erbfall bringt neben Trauer oft auch rechtliche Unsicherheit – wer erbt was, welche
          Pflichten entstehen, wie Streit vermieden wird. Rechtsanwältin Christina Rogalla berät
          Sie einfühlsam und kompetent in allen erbrechtlichen Fragen.
        </p>
        <div class="page-hero__ctas">
          <a href="/kontakt" class="btn btn-secondary btn--lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.4 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012.31 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            Erstberatung anfragen
          </a>
          <a href="tel:+4966317580179" class="btn btn-ghost btn--lg">
            +49 6631 / 758 017 9
          </a>
        </div>
      </div>
    </div>
    <div class="page-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"><path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#f9fafb"/></svg>
    </div>
  </section>

  <!-- ============================================================
       SERVICES
       ============================================================ -->
  <section class="section-padding" aria-labelledby="leistungen-erbrecht">
    <div class="container">
      <div class="section-intro animate-fade-in-up">
        <span class="section-eyebrow">Unsere Leistungen im Erbrecht</span>
        <h2 id="leistungen-erbrecht">Vom Testament bis zum Erbstreit</h2>
        <p class="section-lead">
          Das Erbrecht ist eines der komplexesten Rechtsgebiete im deutschen Recht. Wir begleiten
          Sie als Erblasser, Erbe oder Pflichtteilsberechtigter – kompetent und persönlich.
        </p>
      </div>

      <div class="erbrecht-services">
        <article class="erbrecht-service animate-fade-in-up">
          <div class="erbrecht-service__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
            </svg>
          </div>
          <div class="erbrecht-service__content">
            <h3 class="erbrecht-service__title">Testamentserstellung</h3>
            <p class="erbrecht-service__text">
              Ein gut formuliertes Testament ist das wichtigste Instrument zur Sicherung Ihres letzten
              Willens. Wir beraten Sie zu allen Möglichkeiten – vom einfachen Einzeltestament über
              das gemeinschaftliche Berliner Testament bis hin zu komplexen Gestaltungen mit Vermächtnissen,
              Auflagen und Erbeinsetzungen. Wir stellen sicher, dass Ihr Testament Ihre tatsächlichen
              Wünsche widerspiegelt und vor Gericht Bestand hat.
            </p>
            <div class="erbrecht-service__tags">
              <span class="tag">Einzeltestament</span>
              <span class="tag">Berliner Testament</span>
              <span class="tag">Vermächtnisse</span>
              <span class="tag">Erbvertrag</span>
            </div>
          </div>
        </article>

        <article class="erbrecht-service animate-fade-in-up">
          <div class="erbrecht-service__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="16"/>
              <line x1="8" y1="12" x2="16" y2="12"/>
            </svg>
          </div>
          <div class="erbrecht-service__content">
            <h3 class="erbrecht-service__title">Pflichtteilsrecht</h3>
            <p class="erbrecht-service__text">
              Wer durch ein Testament enterbt wurde, hat dennoch Anspruch auf den gesetzlichen Pflichtteil –
              die Hälfte des gesetzlichen Erbteils. Wir setzen Ihren Pflichtteilsanspruch durch oder
              beraten Sie, wie Sie als Erbe mit Pflichtteilsforderungen umgehen. Pflichtteilsergänzungsansprüche
              bei Schenkungen zu Lebzeiten prüfen wir ebenfalls.
            </p>
            <div class="erbrecht-service__tags">
              <span class="tag">Pflichtteilsanspruch</span>
              <span class="tag">Enterbung</span>
              <span class="tag">Pflichtteilsergänzung</span>
            </div>
          </div>
        </article>

        <article class="erbrecht-service animate-fade-in-up">
          <div class="erbrecht-service__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 00-3-3.87"/>
              <path d="M16 3.13a4 4 0 010 7.75"/>
            </svg>
          </div>
          <div class="erbrecht-service__content">
            <h3 class="erbrecht-service__title">Erbstreit beilegen</h3>
            <p class="erbrecht-service__text">
              Erbstreitigkeiten belasten Familien auf Jahre hinaus. Wir setzen auf außergerichtliche
              Einigung, wo immer möglich – durch Mediation, Verhandlung und klare rechtliche Argumente.
              Wo eine Einigung scheitert, vertreten wir Ihre Interessen konsequent vor dem Nachlassgericht
              und im Klageverfahren.
            </p>
            <div class="erbrecht-service__tags">
              <span class="tag">Erbstreit</span>
              <span class="tag">Mediation</span>
              <span class="tag">Nachlassgericht</span>
              <span class="tag">Erbenfeststellungsklage</span>
            </div>
          </div>
        </article>

        <article class="erbrecht-service animate-fade-in-up">
          <div class="erbrecht-service__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div class="erbrecht-service__content">
            <h3 class="erbrecht-service__title">Testamentsvollstreckung</h3>
            <p class="erbrecht-service__text">
              Der Testamentsvollstrecker sorgt dafür, dass der letzte Wille des Erblassers korrekt
              umgesetzt wird – unabhängig von den Wünschen der Erben. Kanzlei Rogalla übernimmt
              Testamentsvollstreckungen und berät Erblasser bei der Bestimmung eines geeigneten
              Vollstreckers. Eine wichtige Absicherung bei komplexen Nachlässen.
            </p>
            <div class="erbrecht-service__tags">
              <span class="tag">Testamentsvollstrecker</span>
              <span class="tag">Nachlassverwaltung</span>
              <span class="tag">Erblasser beratung</span>
            </div>
          </div>
        </article>

        <article class="erbrecht-service animate-fade-in-up">
          <div class="erbrecht-service__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
              <path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/>
            </svg>
          </div>
          <div class="erbrecht-service__content">
            <h3 class="erbrecht-service__title">Nachlassabwicklung</h3>
            <p class="erbrecht-service__text">
              Die Abwicklung eines Nachlasses ist aufwändig: Schulden müssen ermittelt, Gläubiger
              informiert, Konten aufgelöst, Immobilien übertragen werden. Wir koordinieren die
              gesamte Nachlassabwicklung für Erbengemeinschaften – von der Erbscheinsbeantragung
              bis zur endgültigen Auseinandersetzung unter den Miterben.
            </p>
            <div class="erbrecht-service__tags">
              <span class="tag">Erbschein</span>
              <span class="tag">Erbengemeinschaft</span>
              <span class="tag">Nachlassauseinandersetzung</span>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FAQ
       ============================================================ -->
  <section class="section-padding bg-light" aria-labelledby="faq-erbrecht">
    <div class="container container--md">
      <div class="section-intro animate-fade-in-up">
        <span class="section-eyebrow">Häufige Fragen</span>
        <h2 id="faq-erbrecht">Erbrecht – Ihre Fragen, unsere Antworten</h2>
      </div>

      <div class="faq-list animate-fade-in-up">
        <details class="faq-item">
          <summary class="faq-item__question">
            Was passiert, wenn jemand kein Testament hinterlässt?
            <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="faq-item__answer">
            <p>
              Ohne Testament gilt die gesetzliche Erbfolge nach dem Bürgerlichen Gesetzbuch (BGB).
              Erben erster Ordnung sind die Kinder, dann Enkel. Sind keine Kinder vorhanden, erben
              Eltern und Geschwister. Der überlebende Ehegatte erbt neben Kindern ein Viertel,
              neben Eltern die Hälfte des Nachlasses. Unverheiratete Partner gehen leer aus –
              sie erben nach der gesetzlichen Erbfolge nichts.
            </p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-item__question">
            Kann ich eine Erbschaft ablehnen?
            <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="faq-item__answer">
            <p>
              Ja – die Ausschlagung der Erbschaft ist innerhalb von 6 Wochen nach Kenntnis des
              Erbfalls möglich (beim Erben im Ausland 6 Monate). Sie wird beim Nachlassgericht
              oder einem Notar erklärt. Eine Ausschlagung empfiehlt sich insbesondere, wenn der
              Nachlass überschuldet ist, da der Erbe sonst mit dem Privatvermögen für Nachlassschulden
              haften würde.
            </p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-item__question">
            Wie hoch ist der Pflichtteil und wer hat Anspruch?
            <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="faq-item__answer">
            <p>
              Der Pflichtteil beträgt die Hälfte des gesetzlichen Erbteils und steht nahen Verwandten
              zu, die durch ein Testament enterbt wurden: Kinder (und deren Nachkommen), Eltern
              (wenn keine Kinder vorhanden) sowie der Ehegatte. Geschwister haben keinen Pflichtteilsanspruch.
              Der Pflichtteil ist ein reiner Geldanspruch gegen die Erben – der Pflichtteilsberechtigte
              wird nicht Miterbe.
            </p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-item__question">
            Was ist eine Erbengemeinschaft und wie löst man sie auf?
            <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="faq-item__answer">
            <p>
              Eine Erbengemeinschaft entsteht, wenn mehrere Personen gemeinsam erben. Der Nachlass
              gehört dann allen Miterben gemeinschaftlich – niemand kann über seinen Anteil allein
              verfügen. Zur Auflösung der Erbengemeinschaft muss der Nachlass aufgeteilt werden
              (Erbauseinandersetzung). Dies geschieht idealerweise einvernehmlich durch Vertrag.
              Gelingt keine Einigung, kann jeder Miterbe die Teilungsversteigerung von Immobilien
              erzwingen. Wir begleiten die Auseinandersetzung und suchen pragmatische Lösungen.
            </p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA SECTION
       ============================================================ -->
  <section class="cta-section animate-fade-in-up" aria-label="Beratung anfragen">
    <div class="container">
      <div class="cta-box">
        <div class="cta-box__content">
          <span class="section-eyebrow section-eyebrow--light">Jetzt beraten lassen</span>
          <h2 class="cta-box__title">Erbrechtliche Fragen? Wir haben Antworten.</h2>
          <p class="cta-box__text">
            Ob Sie ein Testament erstellen, einen Pflichtteil geltend machen oder einen Erbstreit
            beilegen möchten – Rechtsanwältin Rogalla steht Ihnen persönlich zur Seite.
            Sprechen Sie uns an.
          </p>
        </div>
        <div class="cta-box__actions">
          <a href="/kontakt" class="btn btn-secondary btn--lg">Erstberatung anfragen</a>
          <a href="tel:+4966317580179" class="btn btn-outline-light btn--lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.4 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012.31 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            +49 6631 / 758 017 9
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
/* ============================================================
   PAGE HERO
   ============================================================ */
.page-hero {
  position: relative;
  background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 60%, var(--navy-mid) 100%);
  padding-block: var(--space-20) calc(var(--space-20) + 40px);
  overflow: hidden;
}

.page-hero__bg {
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(ellipse at 80% 20%, rgb(156 132 102 / 0.12) 0%, transparent 60%),
    radial-gradient(ellipse at 10% 80%, rgb(204 171 113 / 0.07) 0%, transparent 50%);
  pointer-events: none;
}

.page-hero__inner { position: relative; z-index: 1; }
.page-hero__content { max-width: 760px; }

.page-hero__content .breadcrumb {
  margin-bottom: var(--space-6);
  color: rgb(255 255 255 / 0.55);
}

.page-hero__content .breadcrumb a {
  color: rgb(255 255 255 / 0.55);
  transition: color var(--transition-fast);
}

.page-hero__content .breadcrumb a:hover { color: var(--gold-light); }
.page-hero__content .breadcrumb__separator { color: rgb(255 255 255 / 0.3); }
.page-hero__content .badge { margin-bottom: var(--space-5); }

.page-hero__headline {
  font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-5xl));
  font-weight: var(--font-weight-extrabold);
  color: var(--white);
  line-height: 1.1;
  letter-spacing: var(--letter-spacing-tight);
  margin-bottom: var(--space-6);
}

.page-hero__accent { color: var(--gold-light); font-style: normal; }

.page-hero__sub {
  font-size: var(--font-size-lg);
  color: rgb(255 255 255 / 0.78);
  line-height: var(--line-height-relaxed);
  max-width: 60ch;
  margin-bottom: var(--space-8);
}

.page-hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  align-items: center;
}

.page-hero__wave {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  line-height: 0;
}

.page-hero__wave svg { width: 100%; height: 60px; }

.btn-ghost {
  background-color: rgb(255 255 255 / 0.1);
  color: var(--white);
  border: 2px solid rgb(255 255 255 / 0.3);
}

.btn-ghost:hover {
  background-color: rgb(255 255 255 / 0.2);
  border-color: rgb(255 255 255 / 0.6);
  color: var(--white);
}

.btn-outline-light {
  background-color: transparent;
  color: var(--white);
  border-color: rgb(255 255 255 / 0.45);
}

.btn-outline-light:hover {
  background-color: rgb(255 255 255 / 0.12);
  border-color: rgb(255 255 255 / 0.7);
  color: var(--white);
}

/* ============================================================
   SECTION INTRO
   ============================================================ */
.section-intro {
  text-align: center;
  max-width: 680px;
  margin: 0 auto var(--space-12);
}

.section-eyebrow {
  display: inline-block;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  letter-spacing: var(--letter-spacing-widest);
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: var(--space-3);
}

.section-eyebrow--light { color: var(--gold-light); }

.section-intro h2 { margin-bottom: var(--space-4); }

.section-lead {
  font-size: var(--font-size-lg);
  color: var(--text-light);
  line-height: var(--line-height-relaxed);
  max-width: 60ch;
  margin: 0 auto;
}

/* ============================================================
   ERBRECHT SERVICES
   ============================================================ */
.erbrecht-services {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
  max-width: 900px;
  margin: 0 auto;
}

.erbrecht-service {
  display: flex;
  align-items: flex-start;
  gap: var(--space-6);
  background: var(--white);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-2xl);
  padding: 1.75rem;
  box-shadow: var(--shadow-sm);
  transition: box-shadow var(--transition-base), transform var(--transition-base);
}

.erbrecht-service:hover {
  box-shadow: var(--shadow-lg);
  transform: translateY(-2px);
}

.erbrecht-service__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60px;
  height: 60px;
  border-radius: var(--radius-xl);
  background-color: var(--gold-xpale);
  color: var(--gold);
  flex-shrink: 0;
}

.erbrecht-service__content { flex: 1; }

.erbrecht-service__title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--navy);
  margin-bottom: var(--space-3);
}

.erbrecht-service__text {
  color: var(--text-light);
  line-height: var(--line-height-relaxed);
  margin-bottom: var(--space-4);
  max-width: none;
}

.erbrecht-service__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.tag {
  display: inline-block;
  padding: .2rem .65rem;
  border-radius: .3rem;
  font-size: .75rem;
  font-weight: 600;
  background: var(--gold-xpale, #f5efe4);
  color: var(--navy-mid);
  letter-spacing: .01em;
}

/* ============================================================
   FAQ
   ============================================================ */
.faq-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.faq-item {
  background: var(--white);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-xs);
}

.faq-item[open] { box-shadow: var(--shadow-md); }

.faq-item__question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  padding: var(--space-5) var(--space-6);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--navy);
  cursor: pointer;
  list-style: none;
  transition: background-color var(--transition-fast);
}

.faq-item__question::-webkit-details-marker { display: none; }

.faq-item__question:hover { background-color: var(--bg-alt); }

.faq-item[open] .faq-item__question {
  background-color: var(--gold-xpale);
  border-bottom: 1px solid var(--gold-pale);
}

.faq-item__chevron {
  flex-shrink: 0;
  color: var(--gold);
  transition: transform var(--transition-base);
}

.faq-item[open] .faq-item__chevron { transform: rotate(180deg); }

.faq-item__answer { padding: var(--space-5) var(--space-6); }

.faq-item__answer p {
  color: var(--text-light);
  line-height: var(--line-height-relaxed);
  max-width: none;
}

/* ============================================================
   CTA SECTION
   ============================================================ */
.cta-section { padding-block: var(--space-16); }

.cta-box {
