---
// team.astro — About / Team Page
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Christina Rogalla – Rechtsanwältin für Insolvenzrecht | Kanzlei Rogalla"
  description="Rechtsanwältin Christina Rogalla – Diplom-Juristin, DAV-Mitglied, Spezialistin für Insolvenzrecht und Erbrecht mit über 20 Jahren Erfahrung in Alsfeld, Gießen und Offenbach."
>
  <Header slot="header" />

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="page-hero" aria-label="Über Christina Rogalla">
    <div class="page-hero__bg" aria-hidden="true"></div>
    <div class="container page-hero__inner">
      <div class="page-hero__content animate-fade-in-up">
        <span class="badge badge--white">Über uns</span>
        <h1 class="page-hero__headline">
          Ihre Anwältin –<br />
          <em class="page-hero__accent">Christina Rogalla.</em>
        </h1>
        <p class="page-hero__sub">
          Rechtsanwältin und Diplom-Juristin mit über 20 Jahren Erfahrung in Insolvenzrecht,
          Erbrecht und Forderungsmanagement. Persönlich. Direkt. Lösungsorientiert.
        </p>
        <div class="page-hero__ctas">
          <a href="/kontakt" class="btn btn-secondary btn--lg">
            Erstberatung anfragen
          </a>
          <a href="tel:+4966317580179" class="btn btn-ghost btn--lg">
            +49 6631 / 758 017 9
          </a>
        </div>
      </div>
    </div>
    <div class="page-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"><path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#f9fafb"/></svg>
    </div>
  </section>

  <!-- ============================================================
       BIO SECTION
       ============================================================ -->
  <section class="section-padding" aria-labelledby="biografie">
    <div class="container">
      <div class="bio-layout">

        <!-- Portrait -->
        <div class="bio-portrait animate-fade-in-left">
          <div class="bio-portrait__img-wrapper">
            <img src="/images/christina-portrait.jpg"
                 alt="Rechtsanwältin Christina Rogalla"
                 class="bio-portrait__img"
                 width="400" height="500"
                 loading="lazy" />
          </div>
          <div class="portrait-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            DAV-Mitglied
          </div>
        </div>

        <!-- Bio Content -->
        <div class="bio-content animate-fade-in-right">
          <span class="section-eyebrow">Rechtsanwältin & Diplom-Juristin</span>
          <h2 id="biografie">Christina Rogalla – eine Anwältin, der Sie vertrauen können</h2>

          <div class="bio-text">
            <p>
              Christina Rogalla ist seit über 20 Jahren als Rechtsanwältin tätig und hat sich in dieser Zeit
              zu einer der erfahrensten Spezialistinnen für Insolvenzrecht und Erbrecht in Mittelhessen
              entwickelt. Als Diplom-Juristin bringt sie nicht nur formale Qualifikation, sondern vor allem
              tiefes rechtliches Verständnis und praktische Erfahrung in jede Beratung ein.
            </p>

            <p>
              Was Rechtsanwältin Rogalla auszeichnet: Sie nimmt sich Zeit für ihre Mandanten. Keine
              anonymen Beratungsgespräche, kein Durchlaufbetrieb. Jeder Fall wird persönlich bearbeitet,
              jede Situation individuell bewertet. Das Ergebnis ist eine Beratungsqualität, die weit über
              das Übliche hinausgeht.
            </p>

            <p>
              Ihr Spezialgebiet Insolvenzrecht hat sie von Beginn an konsequent verfolgt. Hunderte
              von Mandanten hat sie erfolgreich durch das Insolvenzverfahren begleitet – und in die
              finanzielle Freiheit entlassen. Ihr Leitgedanke dabei: <em>„Es gibt immer einen Ausweg.
              Man muss nur wissen, wie man ihn findet."</em>
            </p>

            <p>
              Neben dem Insolvenzrecht berät sie seit Jahren umfassend im Erbrecht – von der
              Testamentserstellung bis zur Beilegung komplexer Erbstreitigkeiten – sowie im
              Forderungsmanagement für Unternehmen und Privatpersonen. Ihre drei Standorte in
              Alsfeld, Gießen und Offenbach stellen sicher, dass sie für Mandanten in ganz Hessen
              persönlich erreichbar ist.
            </p>
          </div>

          <!-- Quote -->
          <blockquote class="bio-quote">
            <p>„Es gibt immer einen Ausweg. Man muss nur wissen, wie man ihn findet."</p>
            <cite>Christina Rogalla, Rechtsanwältin</cite>
          </blockquote>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       QUALIFICATIONS
       ============================================================ -->
  <section class="section-padding bg-light" aria-labelledby="qualifikationen">
    <div class="container">
      <div class="section-intro animate-fade-in-up">
        <span class="section-eyebrow">Qualifikationen</span>
        <h2 id="qualifikationen">Ausbildung & Mitgliedschaften</h2>
      </div>

      <div class="quals-grid">
        <div class="qual-card animate-fade-in-up">
          <div class="qual-card__icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
              <path d="M6 12v5c3 3 9 3 12 0v-5"/>
            </svg>
          </div>
          <div class="qual-card__content">
            <h3 class="qual-card__title">Rechtsanwältin</h3>
            <p class="qual-card__sub">Zugelassen bei der Rechtsanwaltskammer Frankfurt am Main</p>
          </div>
        </div>

        <div class="qual-card animate-fade-in-up">
          <div class="qual-card__icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
            </svg>
          </div>
          <div class="qual-card__content">
            <h3 class="qual-card__title">Diplom-Juristin</h3>
            <p class="qual-card__sub">Juristische Ausbildung an der Universität – Abschluss mit Diplom</p>
          </div>
        </div>

        <div class="qual-card animate-fade-in-up">
          <div class="qual-card__icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 00-3-3.87"/>
              <path d="M16 3.13a4 4 0 010 7.75"/>
            </svg>
          </div>
          <div class="qual-card__content">
            <h3 class="qual-card__title">DAV-Mitglied</h3>
            <p class="qual-card__sub">Mitglied im Deutschen Anwaltverein (DAV)</p>
          </div>
        </div>

        <div class="qual-card animate-fade-in-up">
          <div class="qual-card__icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3v18M3 9l9-6 9 6M5 19h14"/>
            </svg>
          </div>
          <div class="qual-card__content">
            <h3 class="qual-card__title">Spezialisierung Insolvenzrecht</h3>
            <p class="qual-card__sub">Über 20 Jahre praktische Erfahrung im Insolvenzrecht – Privat- und Regelinsolvenz</p>
          </div>
        </div>

        <div class="qual-card animate-fade-in-up">
          <div class="qual-card__icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <div class="qual-card__content">
            <h3 class="qual-card__title">Erbrecht & Forderungsmanagement</h3>
            <p class="qual-card__sub">Langjährige Erfahrung in Testamentserstellung, Erbstreitigkeiten und Forderungsdurchsetzung</p>
          </div>
        </div>

        <div class="qual-card animate-fade-in-up">
          <div class="qual-card__icon" aria-hidden="true">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div class="qual-card__content">
            <h3 class="qual-card__title">Regional verwurzelt</h3>
            <p class="qual-card__sub">Drei Standorte in Hessen: Alsfeld (Hauptsitz), Gießen, Offenbach</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PHILOSOPHY
       ============================================================ -->
  <section class="section-padding" aria-labelledby="philosophie">
    <div class="container">
      <div class="philosophy-layout animate-fade-in-up">
        <div class="philosophy-content">
          <span class="section-eyebrow">Haltung & Werte</span>
          <h2 id="philosophie">Meine Philosophie als Anwältin</h2>

          <div class="philosophy-text">
            <p>
              Ich bin Rechtsanwältin aus Überzeugung, nicht aus Routine. Jedes Mandat, das ich übernehme,
              behandle ich mit demselben Engagement – ob es um eine einzelne offene Rechnung geht oder
              um einen komplexen Erbstreit, der eine Familie seit Jahren belastet.
            </p>

            <p>
              Mein Ansatz: Zuerst zuhören, dann verstehen, dann handeln. Ich nehme mir die Zeit,
              die Situation meiner Mandanten wirklich zu verstehen – ihre Ängste, ihre Ziele, ihre
              Grenzen. Nur so kann ich Lösungen entwickeln, die wirklich passen.
            </p>

            <p>
              Im Insolvenzrecht, meinem Hauptgebiet, arbeite ich täglich mit Menschen, die am Ende
              ihrer finanziellen Kräfte angelangt sind. Was sie brauchen, ist kein kühler Jurist
              mit Paragraphenreiter, sondern jemand, der ihnen klar sagt, was möglich ist – und
              sie dann verlässlich begleitet. Genau das bin ich.
            </p>
          </div>
        </div>

        <div class="philosophy-values">
          <div class="value-item">
            <div class="value-item__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <div>
              <h3 class="value-item__title">Verlässlichkeit</h3>
              <p class="value-item__text">Was ich verspreche, halte ich. Termine, Rückrufe, Fristen – zuverlässig und pünktlich.</p>
            </div>
          </div>

          <div class="value-item">
            <div class="value-item__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div>
              <h3 class="value-item__title">Menschlichkeit</h3>
              <p class="value-item__text">Meine Mandanten sind Menschen in schwierigen Situationen – keine Aktennummern. Das vergesse ich nie.</p>
            </div>
          </div>

          <div class="value-item">
            <div class="value-item__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <div>
              <h3 class="value-item__title">Klarheit</h3>
              <p class="value-item__text">Ich erkläre Ihnen Ihre Situation verständlich – ohne Juristenjargon und ohne falsche Hoffnungen.</p>
            </div>
          </div>

          <div class="value-item">
            <div class="value-item__icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M3 9l9-6 9 6M5 19h14"/></svg>
            </div>
            <div>
              <h3 class="value-item__title">Kompetenz</h3>
              <p class="value-item__text">20+ Jahre Erfahrung in spezialisierten Rechtsgebieten – für Sie nutzbar gemacht.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA SECTION
       ============================================================ -->
  <section class="cta-section animate-fade-in-up" aria-label="Beratung anfragen">
    <div class="container">
      <div class="cta-box">
        <div class="cta-box__content">
          <span class="section-eyebrow section-eyebrow--light">Lernen Sie mich kennen</span>
          <h2 class="cta-box__title">Ich bin für Sie da.</h2>
          <p class="cta-box__text">
            Vereinbaren Sie eine Erstberatung und erleben Sie persönliche
            Rechtsberatung auf Augenhöhe. Per Telefon, per E-Mail oder in einem meiner
            drei Büros in Hessen.
          </p>
        </div>
        <div class="cta-box__actions">
          <a href="/kontakt" class="btn btn-secondary btn--lg">Erstberatung anfragen</a>
          <a href="tel:+4966317580179" class="btn btn-outline-light btn--lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.4 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012.31 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            +49 6631 / 758 017 9
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
/* ============================================================
   PAGE HERO
   ============================================================ */
.page-hero {
  position: relative;
  background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 60%, var(--navy-mid) 100%);
  padding-block: var(--space-20) calc(var(--space-20) + 40px);
  overflow: hidden;
}

.page-hero__bg {
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(ellipse at 80% 20%, rgb(156 132 102 / 0.12) 0%, transparent 60%),
    radial-gradient(ellipse at 10% 80%, rgb(204 171 113 / 0.07) 0%, transparent 50%);
  pointer-events: none;
}

.page-hero__inner { position: relative; z-index: 1; }
.page-hero__content { max-width: 680px; }
.page-hero__content .badge { margin-bottom: var(--space-5); }

.page-hero__headline {
  font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-5xl));
  font-weight: var(--font-weight-extrabold);
  color: var(--white);
  line-height: 1.1;
  letter-spacing: var(--letter-spacing-tight);
  margin-bottom: var(--space-6);
}

.page-hero__accent { color: var(--gold-light); font-style: normal; }

.page-hero__sub {
  font-size: var(--font-size-lg);
  color: rgb(255 255 255 / 0.78);
  line-height: var(--line-height-relaxed);
  max-width: 55ch;
  margin-bottom: var(--space-8);
}

.page-hero__ctas {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  align-items: center;
}

.page-hero__wave {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  line-height: 0;
}

.page-hero__wave svg { width: 100%; height: 60px; }

.btn-ghost {
  background-color: rgb(255 255 255 / 0.1);
  color: var(--white);
  border: 2px solid rgb(255 255 255 / 0.3);
}

.btn-ghost:hover {
  background-color: rgb(255 255 255 / 0.2);
  border-color: rgb(255 255 255 / 0.6);
  color: var(--white);
}

.btn-outline-light {
  background-color: transparent;
  color: var(--white);
  border-color: rgb(255 255 255 / 0.45);
}

.btn-outline-light:hover {
  background-color: rgb(255 255 255 / 0.12);
  border-color: rgb(255 255 255 / 0.7);
  color: var(--white);
}

/* ============================================================
   SECTION EYEBROW
   ============================================================ */
.section-eyebrow {
  display: inline-block;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  letter-spacing: var(--letter-spacing-widest);
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: var(--space-3);
}

.section-eyebrow--light { color: var(--gold-light); }

/* ============================================================
   SECTION INTRO
   ============================================================ */
.section-intro {
  text-align: center;
  max-width: 680px;
  margin: 0 auto var(--space-12);
}

.section-intro h2 { margin-bottom: var(--space-4); }

/* ============================================================
   BIO LAYOUT
   ============================================================ */
.bio-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-10);
  align-items: flex-start;
}

@media (min-width: 768px) {
  .bio-layout {
    grid-template-columns: 280px 1fr;
    gap: var(--space-12);
  }
}

.bio-portrait {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-4);
}

.bio-portrait__img-wrapper {
  width: 100%;
  max-width: 280px;
  aspect-ratio: 3/4;
  border-radius: var(--radius-3xl);
  overflow: hidden;
  box-shadow: var(--shadow-xl);
  position: relative;
}

.bio-portrait__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.portrait-badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-4);
  background-color: var(--gold-xpale);
  color: var(--gold);
  border: 1px solid var(--gold-pale);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  letter-spacing: var(--letter-spacing-wide);
}

.bio-content h2 { margin-bottom: var(--space-6); }

.bio-text {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  margin-bottom: var(--space-8);
}

.bio-text p {
  color: var(--text-light);
  line-height: var(--line-height-relaxed);
  max-width: none;
}

.bio-text em { color: var(--navy); font-style: italic; }

.bio-quote {
  background-color: var(--gold-xpale);
  border-left: 3px solid var(--gold);
  border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
  padding: var(--space-6) var(--space-8);
  margin: var(--space-8) 0 0;
}

.bio-quote p {
  font-size: var(--font-size-xl);
  font-style: italic;
  color: var(--navy);
  font-weight: var(--font-weight-medium);
  line-height: var(--line-height-snug);
  max-width: none;
  margin: 0;
}

.bio-quote cite {
  display: block;
  margin-top: var(--space-4);
  font-size: var(--font-size-sm);
  font-style: normal;
  color: var(--gold);
  font-weight: var(--font-weight-semibold);
  letter-spacing: var(--letter-spacing-wide);
  text-transform: uppercase;
}

/* ============================================================
   QUALIFICATIONS GRID
   ============================================================ */
.quals-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-4);
}

@media (min-width: 640px) {
  .quals-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1024px) {
  .quals-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.qual-card {
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
  background: var(--white);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-xl);
  padding: var(--space-5) var(--space-6);
  box-shadow: var(--shadow-sm);
  transition: box-shadow var(--transition-base), transform var(--transition-base);
}

.qual-card:hover {
  box-shadow: var(--shadow-lg);
  transform: translateY(-2px);
}

.qual-card__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  border-radius: var(--radius-lg);
  background-color: var(--gold-xpale);
  color: var(--gold);
  flex-shrink: 0;
}

.qual-card__title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--navy);
  margin-bottom: var(--space-1);
}

.qual-card__sub {
  font-size: var(--font-size-sm);
  color: var(--text-muted);
  line-height: var(--line-height-relaxed);
  max-width: none;
}

/* ============================================================
   PHILOSOPHY
   ============================================================ */
.philosophy-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-12);
  align-items: flex-start;
}

@media (min-width: 1024px) {
  .philosophy-layout {
    grid-template-columns: 1fr 380px;
  }
}

.philosophy-content h2 { margin-bottom: var(--space-6); }

.philosophy-text {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.philosophy-text p {
  color: var(--text-light);
  line-height: var(--line-height-relaxed);
  max-width: none;
}

.philosophy-values {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

.value-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
