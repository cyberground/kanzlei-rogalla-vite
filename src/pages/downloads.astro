---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const downloads = [
  {
    category: 'Insolvenzrecht',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    docs: [
      {
        title: 'Selbstauskunft Vermögenslage',
        desc: 'Übersicht über Einnahmen, Ausgaben und Verbindlichkeiten – Voraussetzung für die Beantragung der Privatinsolvenz.',
        file: '/downloads/selbstauskunft-vermoegenslage.pdf',
        pages: '4 Seiten',
      },
      {
        title: 'Checkliste Privatinsolvenz',
        desc: 'Schritt-für-Schritt Anleitung: Was Sie vor, während und nach dem Insolvenzantrag wissen müssen.',
        file: '/downloads/checkliste-privatinsolvenz.pdf',
        pages: '2 Seiten',
      },
      {
        title: 'Checkliste Unternehmensinsolvenz',
        desc: 'Wichtige Punkte für Selbstständige und Unternehmer bei drohender Zahlungsunfähigkeit.',
        file: '/downloads/checkliste-unternehmensinsolvenz.pdf',
        pages: '3 Seiten',
      },
    ],
  },
  {
    category: 'Vorsorge & Erbrecht',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    docs: [
      {
        title: 'Muster Vorsorgevollmacht',
        desc: 'Vollmacht für Ihre Vertrauensperson – für Banken, Behörden und medizinische Entscheidungen.',
        file: '/downloads/muster-vorsorgevollmacht.pdf',
        pages: '3 Seiten',
      },
      {
        title: 'Muster Patientenverfügung',
        desc: 'Schriftliche Festlegung Ihrer Wünsche für medizinische Behandlungen – rechtssicher formuliert.',
        file: '/downloads/muster-patientenverfuegung.pdf',
        pages: '2 Seiten',
      },
      {
        title: 'Checkliste Nachlassplanung',
        desc: 'Was Sie regeln sollten, bevor es zu spät ist – Testament, Vollmacht, Verfügung im Überblick.',
        file: '/downloads/checkliste-nachlassplanung.pdf',
        pages: '2 Seiten',
      },
    ],
  },
  {
    category: 'Forderungsmanagement',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`,
    docs: [
      {
        title: 'Muster Mahnung (1. Stufe)',
        desc: 'Professionelles Muster-Mahnschreiben für offene Forderungen mit korrekten Rechtshinweisen.',
        file: '/downloads/muster-mahnung.pdf',
        pages: '1 Seite',
      },
      {
        title: 'Checkliste Forderungsdurchsetzung',
        desc: 'Von der Mahnung bis zur Zwangsvollstreckung – alle Schritte erklärt.',
        file: '/downloads/checkliste-forderung.pdf',
        pages: '2 Seiten',
      },
    ],
  },
];
---

<Layout
  title="Downloads – Formulare & Dokumente | Kanzlei Rogalla"
  description="Formulare und Mustervorlagen zum Herunterladen: Selbstauskunft Vermögenslage, Checkliste Privatinsolvenz, Vorsorgevollmacht, Patientenverfügung und mehr."
>
  <Header slot="header" />

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="page-hero" aria-label="Downloads">
    <div class="page-hero__bg" aria-hidden="true"></div>
    <div class="container page-hero__inner">
      <div class="page-hero__content animate-fade-in-up">
        <nav class="breadcrumb" aria-label="Brotkrumennavigation">
          <div class="breadcrumb__item">
            <a href="/">Home</a>
            <svg class="breadcrumb__separator" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
          <div class="breadcrumb__item" aria-current="page">Downloads</div>
        </nav>
        <span class="badge badge--white">PDF Download</span>
        <h1 class="page-hero__headline">
          Formulare &<br />
          <em class="page-hero__accent">Mustervorlagen.</em>
        </h1>
        <p class="page-hero__sub">
          Laden Sie unsere Formulare und Checklisten herunter –
          sorgfältig aufbereitet von Rechtsanwältin Christina Rogalla.
          Bei Fragen stehen wir Ihnen jederzeit persönlich zur Verfügung.
        </p>
      </div>
    </div>
    <div class="page-hero__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg"><path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#f9fafb"/></svg>
    </div>
  </section>

  <!-- ============================================================
       HINWEIS
       ============================================================ -->
  <section class="section-padding--sm bg-light">
    <div class="container">
      <div class="info-banner animate-fade-in-up">
        <div class="info-banner__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <p class="info-banner__text">
          Die Formulare dienen als <strong>Orientierungshilfe</strong> und ersetzen keine individuelle Rechtsberatung.
          Für Ihren konkreten Fall empfehlen wir eine persönliche Erstberatung –
          <a href="/kontakt" class="info-banner__link">unverbindlich</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       DOWNLOADS
       ============================================================ -->
  <section class="section-padding" aria-labelledby="downloads-heading">
    <div class="container">
      <div class="section-intro animate-fade-in-up">
        <span class="section-eyebrow">Alle Formulare</span>
        <h2 id="downloads-heading">Unsere Dokumente</h2>
        <p class="section-lead">
          Alle Dokumente sind im PDF-Format und können direkt heruntergeladen werden.
        </p>
      </div>

      {downloads.map((group) => (
        <div class="download-group animate-fade-in-up">
          <div class="download-group__header">
            <div class="download-group__icon" aria-hidden="true" set:html={group.icon} />
            <h2 class="download-group__title">{group.category}</h2>
          </div>
          <div class="download-grid">
            {group.docs.map((doc) => (
              <div class="download-card">
                <div class="download-card__pdf-icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                  </svg>
                  <span class="download-card__pdf-label">PDF</span>
                </div>
                <div class="download-card__content">
                  <h3 class="download-card__title">{doc.title}</h3>
                  <p class="download-card__desc">{doc.desc}</p>
                  <div class="download-card__meta">
                    <span class="download-card__pages">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                      {doc.pages}
                    </span>
                    <span class="download-card__type">PDF</span>
                  </div>
                </div>
                <a
                  href={doc.file}
                  class="download-card__btn"
                  download
                  aria-label={`${doc.title} herunterladen (PDF)`}
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                  </svg>
                  Herunterladen
                </a>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ============================================================
       CTA
       ============================================================ -->
  <section class="cta-section animate-fade-in-up" aria-label="Persönliche Beratung">
    <div class="container">
      <div class="cta-box">
        <div class="cta-box__content">
          <span class="section-eyebrow section-eyebrow--light">Individuelle Beratung</span>
          <h2 class="cta-box__title">Formulare allein reichen oft nicht.</h2>
          <p class="cta-box__text">
            Jeder Fall ist einzigartig. Rechtsanwältin Christina Rogalla berät Sie persönlich –
            unverbindlich. Vereinbaren Sie jetzt Ihr erstes Gespräch.
          </p>
        </div>
        <div class="cta-box__actions">
          <a href="/kontakt" class="btn btn-secondary btn--lg">Erstberatung anfragen</a>
          <a href="tel:+4966317580179" class="btn btn-outline-light btn--lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.4 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012.31 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            +49 6631 / 758 017 9
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
/* PAGE HERO */
.page-hero {
  position: relative;
  background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 60%, var(--navy-mid) 100%);
  padding-block: var(--space-20) calc(var(--space-20) + 40px);
  overflow: hidden;
}
.page-hero__bg {
  position: absolute; inset: 0;
  background-image:
    radial-gradient(ellipse at 80% 20%, rgb(156 132 102 / 0.12) 0%, transparent 60%),
    radial-gradient(ellipse at 10% 80%, rgb(204 171 113 / 0.07) 0%, transparent 50%);
  pointer-events: none;
}
.page-hero__inner { position: relative; z-index: 1; }
.page-hero__content { max-width: 760px; }
.page-hero__content .breadcrumb { margin-bottom: var(--space-6); color: rgb(255 255 255 / 0.55); }
.page-hero__content .breadcrumb a { color: rgb(255 255 255 / 0.55); transition: color var(--transition-fast); }
.page-hero__content .breadcrumb a:hover { color: var(--gold-light); }
.page-hero__content .breadcrumb__separator { color: rgb(255 255 255 / 0.3); }
.page-hero__content .badge { margin-bottom: var(--space-5); }
.page-hero__headline {
  font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-5xl));
  font-weight: var(--font-weight-extrabold);
  color: var(--white);
  line-height: 1.1;
  letter-spacing: var(--letter-spacing-tight);
  margin-bottom: var(--space-6);
}
.page-hero__accent { color: var(--gold-light); font-style: normal; }
.page-hero__sub {
  font-size: var(--font-size-lg);
  color: rgb(255 255 255 / 0.78);
  line-height: var(--line-height-relaxed);
  max-width: 60ch;
}
.page-hero__wave { position: absolute; bottom: 0; left: 0; right: 0; line-height: 0; }
.page-hero__wave svg { width: 100%; height: 60px; }

/* INFO BANNER */
.info-banner {
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
  background: var(--gold-xpale);
  border: 1px solid var(--gold-pale);
  border-left: 4px solid var(--gold);
  border-radius: var(--radius-xl);
  padding: var(--space-5) var(--space-6);
}
.info-banner__icon { color: var(--gold-dark); flex-shrink: 0; margin-top: 2px; }
.info-banner__text { font-size: var(--font-size-sm); color: var(--text-light); line-height: var(--line-height-relaxed); max-width: none; }
.info-banner__text strong { color: var(--navy); }
.info-banner__link { color: var(--navy); font-weight: var(--font-weight-semibold); text-decoration: underline; text-underline-offset: 3px; }
.info-banner__link:hover { color: var(--gold-dark); }

/* SECTION INTRO */
.section-intro { text-align: center; max-width: 680px; margin: 0 auto var(--space-12); }
.section-intro h2 { margin-bottom: var(--space-4); }
.section-lead { font-size: var(--font-size-lg); color: var(--text-light); line-height: var(--line-height-relaxed); max-width: 60ch; margin: 0 auto; }

/* DOWNLOAD GROUPS */
.download-group { margin-bottom: var(--space-16); }
.download-group:last-child { margin-bottom: 0; }

.download-group__header {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  margin-bottom: var(--space-8);
  padding-bottom: var(--space-5);
  border-bottom: 2px solid var(--border-light);
}
.download-group__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52px;
  height: 52px;
  border-radius: var(--radius-xl);
  background: var(--gold-xpale);
  color: var(--gold-dark);
  flex-shrink: 0;
}
.download-group__title {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-bold);
  color: var(--navy);
}

/* DOWNLOAD GRID */
.download-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-5);
}
@media (min-width: 768px) {
  .download-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 1024px) {
  .download-grid { grid-template-columns: repeat(3, 1fr); }
}

/* DOWNLOAD CARD */
.download-card {
  background: var(--white);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-2xl);
  padding: var(--space-6);
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  transition: box-shadow var(--transition-base), transform var(--transition-base);
}
.download-card:hover {
  box-shadow: var(--shadow-lg);
  transform: translateY(-3px);
}

.download-card__pdf-icon {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  color: #e53e3e;
}
.download-card__pdf-label {
  font-size: 0.7rem;
  font-weight: 800;
  letter-spacing: .08em;
  color: #e53e3e;
}

.download-card__content { flex: 1; }
.download-card__title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  color: var(--navy);
  margin-bottom: var(--space-2);
  line-height: var(--line-height-snug);
}
.download-card__desc {
  font-size: var(--font-size-sm);
  color: var(--text-light);
  line-height: var(--line-height-relaxed);
  max-width: none;
  margin-bottom: var(--space-3);
}
.download-card__meta {
  display: flex;
  align-items: center;
  gap: var(--space-4);
}
.download-card__pages {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--font-size-xs);
  color: var(--text-light);
}
.download-card__type {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  color: var(--gold-dark);
  background: var(--gold-xpale);
  padding: .15rem .5rem;
  border-radius: var(--radius-full);
}

.download-card__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  width: 100%;
  padding: var(--space-3) var(--space-4);
  background: var(--navy);
  color: var(--white);
  border: 2px solid var(--navy);
  border-radius: var(--radius-lg);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  text-decoration: none;
  transition: background-color var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
}
.download-card__btn:hover {
  background: var(--gold);
  border-color: var(--gold);
  color: var(--navy-dark);
  transform: translateY(-1px);
}

/* CTA */
.cta-section { padding-block: var(--space-16); }
.btn-outline-light {
  background-color: transparent;
  color: var(--white);
  border-color: rgb(255 255 255 / 0.45);
}
.btn-outline-light:hover {
  background-color: rgb(255 255 255 / 0.12);
  border-color: rgb(255 255 255 / 0.7);
  color: var(--white);
}
</style>
