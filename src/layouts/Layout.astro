---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title,
  description = 'Rechtsanwaltskanzlei Christina Rogalla – Spezialistin für Insolvenzrecht und Erbrecht in Alsfeld, Gießen und Offenbach.',
  ogImage = '/images/christina-portrait.jpg',
  canonical,
  type = 'website',
  noindex = false,
} = Astro.props;

const siteUrl = 'https://kanzlei-rogalla.de';
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const ogImageAbsolute = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const orgSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LegalService",
      "@id": `${siteUrl}/#organization`,
      "name": "Rechtsanwaltskanzlei Christina Rogalla",
      "alternateName": "Kanzlei Rogalla",
      "url": siteUrl,
      "logo": {
        "@type": "ImageObject",
        "url": `${siteUrl}/images/logo.png`,
        "width": 300,
        "height": 80
      },
      "image": `${siteUrl}/images/christina-portrait.jpg`,
      "description": "Rechtsanwaltskanzlei für Insolvenzrecht, Erbrecht und Forderungsmanagement in Alsfeld, Gießen und Offenbach am Main. Erstberatung anfragen.",
      "telephone": "+4966317580179",
      "priceRange": "€€",
      "knowsAbout": ["Insolvenzrecht", "Privatinsolvenz", "Restschuldbefreiung", "Erbrecht", "Testament", "Pflichtteil", "Forderungsmanagement", "Vorsorgevollmacht", "Patientenverfügung"],
      "areaServed": [
        { "@type": "City", "name": "Alsfeld" },
        { "@type": "City", "name": "Gießen" },
        { "@type": "City", "name": "Offenbach am Main" },
        { "@type": "State", "name": "Hessen" }
      ],
      "founder": {
        "@type": "Person",
        "name": "Christina Rogalla",
        "jobTitle": "Rechtsanwältin",
        "image": `${siteUrl}/images/christina-portrait.jpg`
      },
      "location": [
        {
          "@type": "LocalBusiness",
          "name": "Kanzlei Rogalla – Alsfeld",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Markt 9",
            "addressLocality": "Alsfeld",
            "postalCode": "36304",
            "addressRegion": "Hessen",
            "addressCountry": "DE"
          },
          "telephone": "+4966317580179",
          "url": siteUrl
        },
        {
          "@type": "LocalBusiness",
          "name": "Kanzlei Rogalla – Gießen",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Ursulum 14",
            "addressLocality": "Gießen",
            "postalCode": "35396",
            "addressRegion": "Hessen",
            "addressCountry": "DE"
          },
          "telephone": "+4966317580179"
        },
        {
          "@type": "LocalBusiness",
          "name": "Kanzlei Rogalla – Offenbach am Main",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Berliner Str. 256",
            "addressLocality": "Offenbach am Main",
            "postalCode": "63066",
            "addressRegion": "Hessen",
            "addressCountry": "DE"
          },
          "telephone": "+4966317580179"
        }
      ]
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "Kanzlei Rogalla",
      "description": "Rechtsanwältin für Insolvenzrecht & Erbrecht in Alsfeld, Gießen und Offenbach",
      "inLanguage": "de-DE",
      "publisher": { "@id": `${siteUrl}/#organization` }
    }
  ]
};
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Titel & Beschreibung -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
  <meta name="author" content="Rechtsanwältin Christina Rogalla" />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Geo / Lokale Relevanz -->
  <meta name="geo.region" content="DE-HE" />
  <meta name="geo.placename" content="Alsfeld, Gießen, Offenbach am Main" />
  <meta name="geo.position" content="50.7511;9.2694" />
  <meta name="ICBM" content="50.7511, 9.2694" />

  <!-- Open Graph (Facebook, LinkedIn, WhatsApp) -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageAbsolute} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Rechtsanwältin Christina Rogalla – Kanzlei Rogalla" />
  <meta property="og:site_name" content="Kanzlei Rogalla" />
  <meta property="og:locale" content="de_DE" />

  <!-- Twitter / X Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbsolute} />
  <meta name="twitter:image:alt" content="Rechtsanwältin Christina Rogalla – Kanzlei Rogalla" />

  <!-- PWA / Mobile -->
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#023A51" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Kanzlei Rogalla" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,400&family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="shortcut icon" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />

  <!-- JSON-LD: Organisation + WebSite (global) -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <!-- Seitenspezifisches JSON-LD (z.B. Article aus Blog) -->
  <slot name="head" />
</head>
<body>
  <slot name="header" />
  <main>
    <slot />
  </main>
  <slot name="footer" />
</body>
</html>

<style is:global>
/* ============================================================
   CSS RESET & BASE
   ============================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
img, video { max-width: 100%; height: auto; display: block; }
a { color: inherit; text-decoration: none; }
button { cursor: pointer; border: none; background: none; font: inherit; }
ul, ol { list-style: none; }
h1,h2,h3,h4,h5,h6 { font-weight: var(--font-weight-bold); line-height: var(--line-height-tight); }

/* ============================================================
   CSS VARIABLES (DESIGN SYSTEM)
   ============================================================ */
:root {
  /* Farben */
  --navy-dark: #012030;
  --navy: #023A51;
  --navy-mid: #0D5473;
  --gold-dark: #A8853A;
  --gold: #CCAB71;
  --gold-light: #D9BC8A;
  --gold-pale: #E8D5A8;
  --gold-xpale: #F5EDD8;
  --white: #FFFFFF;
  --text: #1A202C;
  --text-light: #4A5568;
  --bg: #FFFFFF;
  --bg-alt: #F9FAFB;
  --border-light: #E2E8F0;

  /* Spacing */
  --space-1: 0.25rem; --space-2: 0.5rem; --space-3: 0.75rem; --space-4: 1rem;
  --space-5: 1.25rem; --space-6: 1.5rem; --space-8: 2rem; --space-10: 2.5rem;
  --space-12: 3rem; --space-16: 4rem; --space-20: 5rem; --space-24: 6rem;

  /* Font Sizes */
  --font-size-xs: 0.8rem; --font-size-sm: 0.925rem; --font-size-base: 1.075rem;
  --font-size-lg: 1.2rem; --font-size-xl: 1.35rem; --font-size-2xl: 1.6rem;
  --font-size-3xl: 2rem; --font-size-4xl: 2.5rem; --font-size-5xl: 3.25rem;

  /* Font Weights */
  --font-weight-normal: 400; --font-weight-medium: 500;
  --font-weight-semibold: 600; --font-weight-bold: 700; --font-weight-extrabold: 800;

  /* Line Heights */
  --line-height-tight: 1.2; --line-height-snug: 1.35;
  --line-height-normal: 1.5; --line-height-relaxed: 1.7;

  /* Letter Spacing */
  --letter-spacing-tight: -0.02em; --letter-spacing-normal: 0;
  --letter-spacing-wide: 0.05em; --letter-spacing-wider: 0.08em;
  --letter-spacing-widest: 0.12em;

  /* Border Radius */
  --radius-sm: 0.25rem; --radius-md: 0.375rem; --radius-lg: 0.5rem;
  --radius-xl: 0.75rem; --radius-2xl: 1rem; --radius-3xl: 1.5rem;
  --radius-full: 9999px;

  /* Shadows */
  --shadow-xs: 0 1px 2px rgb(0 0 0 / 0.05);
  --shadow-sm: 0 1px 3px rgb(0 0 0 / 0.1), 0 1px 2px rgb(0 0 0 / 0.06);
  --shadow-md: 0 4px 6px rgb(0 0 0 / 0.07), 0 2px 4px rgb(0 0 0 / 0.06);
  --shadow-lg: 0 10px 15px rgb(0 0 0 / 0.1), 0 4px 6px rgb(0 0 0 / 0.05);
  --shadow-xl: 0 20px 25px rgb(0 0 0 / 0.1), 0 10px 10px rgb(0 0 0 / 0.04);

  /* Transitions */
  --transition-fast: 150ms ease;
  --transition-base: 250ms ease;
}

/* ============================================================
   TYPOGRAPHY
   ============================================================ */
body {
  font-family: 'Lato', system-ui, sans-serif;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-normal);
  line-height: var(--line-height-relaxed);
  color: var(--text);
  background-color: var(--bg);
}

h1, h2, h3, h4, h5, h6 {
  font-family: 'Playfair Display', Georgia, serif;
  color: var(--navy);
  letter-spacing: var(--letter-spacing-tight);
}

h1 { font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-5xl)); }
h2 { font-size: clamp(var(--font-size-2xl), 3.5vw, var(--font-size-4xl)); }
h3 { font-size: clamp(var(--font-size-xl), 2.5vw, var(--font-size-2xl)); }

p { max-width: 70ch; }

/* ============================================================
   LAYOUT UTILITIES
   ============================================================ */
.container {
  width: 100%;
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: var(--space-6);
}

@media (min-width: 1400px) {
  .container { max-width: 1320px; }
}

.container--md { max-width: 800px; }
.container--sm { max-width: 640px; }

.section-padding {
  padding-block: var(--space-20);
}

.section-padding--sm {
  padding-block: var(--space-12);
}

.bg-light { background-color: var(--bg-alt); }
.sr-only {
  position: absolute; width: 1px; height: 1px;
  padding: 0; margin: -1px; overflow: hidden;
  clip: rect(0,0,0,0); white-space: nowrap; border: 0;
}

/* ============================================================
   BUTTONS
   ============================================================ */
.btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-6);
  border-radius: var(--radius-lg);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  font-family: 'Lato', sans-serif;
  line-height: 1;
  border: 2px solid transparent;
  text-decoration: none;
  cursor: pointer;
  transition: background-color var(--transition-fast), color var(--transition-fast),
              border-color var(--transition-fast), transform var(--transition-fast),
              box-shadow var(--transition-fast);
  white-space: nowrap;
}

.btn:hover { transform: translateY(-1px); }
.btn:active { transform: none; }

.btn--lg {
  padding: var(--space-4) var(--space-8);
  font-size: var(--font-size-lg);
}

.btn-primary {
  background-color: var(--gold);
  color: var(--white);
  border-color: var(--gold);
}
.btn-primary:hover {
  background-color: var(--gold-dark);
  border-color: var(--gold-dark);
  box-shadow: var(--shadow-md);
}

.btn-secondary {
  background-color: var(--gold);
  color: var(--navy-dark);
  border-color: var(--gold);
}
.btn-secondary:hover {
  background-color: var(--gold-light);
  border-color: var(--gold-light);
  box-shadow: var(--shadow-md);
}

.btn-ghost {
  background-color: transparent;
  color: var(--white);
  border-color: rgb(255 255 255 / 0.35);
}
.btn-ghost:hover {
  background-color: rgb(255 255 255 / 0.12);
  border-color: rgb(255 255 255 / 0.6);
  color: var(--white);
}

.btn-outline {
  background-color: transparent;
  color: var(--navy);
  border-color: var(--navy);
}
.btn-outline:hover {
  background-color: var(--navy);
  color: var(--white);
}

.btn-outline-light {
  background-color: transparent;
  color: var(--white);
  border-color: rgb(255 255 255 / 0.45);
}
.btn-outline-light:hover {
  background-color: rgb(255 255 255 / 0.12);
  border-color: rgb(255 255 255 / 0.7);
  color: var(--white);
}

/* ============================================================
   BADGE
   ============================================================ */
.badge {
  display: inline-flex;
  align-items: center;
  padding: var(--space-1) var(--space-4);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  letter-spacing: var(--letter-spacing-widest);
  text-transform: uppercase;
  background-color: var(--gold-xpale);
  color: var(--gold-dark);
  border: 1px solid var(--gold-pale);
}

.badge--white {
  background-color: rgb(255 255 255 / 0.15);
  color: var(--white);
  border-color: rgb(255 255 255 / 0.3);
}

.badge--navy {
  background-color: rgb(2 58 81 / 0.1);
  color: var(--navy);
  border-color: rgb(2 58 81 / 0.2);
}

/* ============================================================
   BREADCRUMB
   ============================================================ */
.breadcrumb {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  flex-wrap: wrap;
}

.breadcrumb__item {
  display: flex;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--font-size-sm);
}

.breadcrumb__separator {
  opacity: 0.5;
}

/* ============================================================
   SECTION SHARED STYLES
   ============================================================ */
.section-eyebrow {
  display: inline-block;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  letter-spacing: var(--letter-spacing-widest);
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: var(--space-3);
  font-family: 'Lato', sans-serif;
}

.section-eyebrow--light { color: var(--gold-light); }

.section-intro {
  text-align: center;
  max-width: 680px;
  margin: 0 auto var(--space-12);
}

.section-intro h2 { margin-bottom: var(--space-4); }

.section-lead {
  font-size: var(--font-size-lg);
  color: var(--text-light);
  line-height: var(--line-height-relaxed);
  max-width: 60ch;
  margin: 0 auto;
}

/* PAGE HERO */
.page-hero {
  position: relative;
  background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 60%, var(--navy-mid) 100%);
  padding-block: var(--space-20) calc(var(--space-20) + 40px);
  overflow: hidden;
}

.page-hero__bg {
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(ellipse at 80% 20%, rgb(156 132 102 / 0.12) 0%, transparent 60%),
    radial-gradient(ellipse at 10% 80%, rgb(204 171 113 / 0.07) 0%, transparent 50%);
  pointer-events: none;
}

.page-hero__inner { position: relative; z-index: 1; }
.page-hero__content { max-width: 760px; }
.page-hero__content .breadcrumb { margin-bottom: var(--space-6); color: rgb(255 255 255 / 0.55); }
.page-hero__content .breadcrumb a { color: rgb(255 255 255 / 0.55); transition: color var(--transition-fast); }
.page-hero__content .breadcrumb a:hover { color: var(--gold-light); }
.page-hero__content .breadcrumb__separator { color: rgb(255 255 255 / 0.3); }
.page-hero__content .badge { margin-bottom: var(--space-5); }

.page-hero__headline {
  font-size: clamp(var(--font-size-3xl), 5vw, var(--font-size-5xl));
  font-weight: var(--font-weight-extrabold);
  color: var(--white);
  line-height: 1.1;
  letter-spacing: var(--letter-spacing-tight);
  margin-bottom: var(--space-6);
}

.page-hero__accent { color: var(--gold-light); font-style: normal; }

.page-hero__sub {
  font-size: var(--font-size-lg);
  color: rgb(255 255 255 / 0.78);
  line-height: var(--line-height-relaxed);
  max-width: 60ch;
  margin-bottom: var(--space-8);
}

.page-hero__ctas { display: flex; flex-wrap: wrap; gap: var(--space-4); align-items: center; }

.page-hero__wave {
  position: absolute; bottom: 0; left: 0; right: 0; line-height: 0;
}
.page-hero__wave svg { width: 100%; height: 60px; }

/* ============================================================
   CTA SHARED
   ============================================================ */
.cta-section { padding-block: var(--space-16); }

.cta-box {
  background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 100%);
  border-radius: var(--radius-3xl);
  padding: var(--space-12) var(--space-10);
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
  align-items: flex-start;
  position: relative;
  overflow: hidden;
}

.cta-box::before {
  content: '';
  position: absolute;
  top: -60px; right: -60px;
  width: 300px; height: 300px;
  border-radius: 50%;
  background: radial-gradient(circle, rgb(204 171 113 / 0.15) 0%, transparent 70%);
  pointer-events: none;
}

@media (min-width: 768px) {
  .cta-box { flex-direction: row; align-items: center; justify-content: space-between; }
}

.cta-box__content { flex: 1; }
.cta-box__title {
  font-size: clamp(var(--font-size-2xl), 3vw, var(--font-size-4xl));
  font-weight: var(--font-weight-bold);
  color: var(--white);
  margin-bottom: var(--space-4);
}
.cta-box__text { color: rgb(255 255 255 / 0.72); line-height: var(--line-height-relaxed); max-width: 52ch; }
.cta-box__actions { display: flex; flex-direction: column; gap: var(--space-3); flex-shrink: 0; }
@media (min-width: 640px) { .cta-box__actions { flex-direction: row; align-items: center; } }

/* ============================================================
   ANIMATIONS
   ============================================================ */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeInLeft {
  from { opacity: 0; transform: translateX(-24px); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes fadeInRight {
  from { opacity: 0; transform: translateX(24px); }
  to { opacity: 1; transform: translateX(0); }
}

.animate-fade-in-up {
  animation: fadeInUp 0.6s ease both;
}

.animate-fade-in-left {
  animation: fadeInLeft 0.6s ease both;
}

.animate-fade-in-right {
  animation: fadeInRight 0.6s ease both;
}

/* FAQ shared */
.faq-list { display: flex; flex-direction: column; gap: var(--space-3); }

.faq-item {
  background: var(--white);
  border: 1px solid var(--border-light);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-xs);
}

.faq-item[open] { box-shadow: var(--shadow-md); }

.faq-item__question {
  display: flex; align-items: center; justify-content: space-between;
  gap: var(--space-4); padding: var(--space-5) var(--space-6);
  font-size: var(--font-size-base); font-weight: var(--font-weight-semibold);
  color: var(--navy); cursor: pointer; list-style: none;
  transition: background-color var(--transition-fast);
  font-family: 'Lato', sans-serif;
}
.faq-item__question::-webkit-details-marker { display: none; }
.faq-item__question:hover { background-color: var(--bg-alt); }
.faq-item[open] .faq-item__question { background-color: var(--gold-xpale); color: var(--navy); border-bottom: 1px solid var(--gold-pale); }
.faq-item__chevron { flex-shrink: 0; color: var(--gold); transition: transform var(--transition-base); }
.faq-item[open] .faq-item__chevron { transform: rotate(180deg); }
.faq-item__answer { padding: var(--space-5) var(--space-6); }
.faq-item__answer p { color: var(--text-light); line-height: var(--line-height-relaxed); max-width: none; }
</style>
